## Visual Studio Template
## Ignore Visual Studio temporary files, build results, and user-specific settings.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Log]/
[Logs]/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create to-do list files
#*.tasks

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
CompileLog.txt

# OLAP DB files
*.ovf
*.tbl
*.odf
*.rot
*.index

# Task Studio basic filters
*.layout

# Free edition filter
*.filter

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/
.history/

# User-specific files
appsettings.Development.json
appsettings.Local.json
*.db

# Publish
*publish/
*.pubxml
*.pubxml.user

# Windows temp files
Thumbs.db
ehthumbs.db
Desktop.ini
