@model QLKhachSan.Controllers.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống - Hotel</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@600;700;850&display=swap" rel="stylesheet">
    
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="auth-bg">
        <div class="auth-card">
            <div class="text-center mb-4">
                <i class="fa-solid fa-hotel fs-1 text-primary mb-2"></i>
                <h3 class="m-0 font-weight-bold" style="font-family: 'Outfit', sans-serif;">ROYAL HOTEL</h3>
                <p class="text-muted small">Hệ thống Quản lý Khách sạn hoàn chỉnh</p>
            </div>
            
            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <div class="mb-3">
                    <label asp-for="Username" class="form-label text-light small"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-secondary text-light"><i class="fa-solid fa-user"></i></span>
                        <input asp-for="Username" class="form-control bg-transparent border-secondary text-light" placeholder="Nhập tên đăng nhập" autocomplete="off" />
                    </div>
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Password" class="form-label text-light small"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-secondary text-light"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="Password" class="form-control bg-transparent border-secondary text-light" placeholder="Nhập mật khẩu" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                
                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input bg-transparent border-secondary" />
                    <label asp-for="RememberMe" class="form-check-label text-light small"></label>
                </div>
                
                <button type="submit" class="btn btn-primary-custom w-100 py-2 fs-6 mb-3">
                    <i class="fa-solid fa-right-to-bracket me-2"></i>ĐĂNG NHẬP
                </button>
            </form>
            
            <div class="text-center pt-2 text-muted small border-top border-secondary">
                <p class="m-0">Tài khoản demo: <strong>admin</strong> | Mật khẩu: <strong>1234</strong></p>
                <a href="/Account/Seed" class="text-primary text-decoration-none mt-2 d-inline-block"><i class="fa-solid fa-database me-1"></i>Kích hoạt CSDL mẫu (Seed)</a>
            </div>
        </div>
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
