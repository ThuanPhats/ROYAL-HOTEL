@model dynamic
@{
    ViewData["Title"] = "Bàn giao thiết bị";
    var rooms = ViewBag.Rooms as IEnumerable<QLKhachSan.Models.Phong> ?? new List<QLKhachSan.Models.Phong>();
    var assets = ViewBag.Assets as IEnumerable<QLKhachSan.Models.ThietBi> ?? new List<QLKhachSan.Models.ThietBi>();
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-box-seam me-2"></i>Bàn giao thiết bị vào phòng</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Allocate" method="post" asp-antiforgery="true">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label for="assetId" class="form-label font-weight-bold">Chọn thiết bị cần bàn giao</label>
                            <select id="assetId" name="assetId" class="form-select" required>
                                <option value="">-- Chọn thiết bị --</option>
                                @foreach (var asset in assets)
                                {
                                    <option value="@asset.Id">@asset.TenThietBi (@asset.MaTaiSan) - Trạng thái: @asset.TrangThai</option>
                                }
                            </select>
                            <span class="text-danger" data-valmsg-for="assetId" data-valmsg-replace="true"></span>
                        </div>

                        <div class="mb-3">
                            <label for="roomId" class="form-label font-weight-bold">Chọn phòng nhận bàn giao</label>
                            <select id="roomId" name="roomId" class="form-select" required>
                                <option value="">-- Chọn phòng --</option>
                                @foreach (var room in rooms)
                                {
                                    <option value="@room.Id">Phòng @room.MaPhong - Tầng @room.Tang (@(room.LoaiPhong?.TenLoaiPhong))</option>
                                }
                            </select>
                            <span class="text-danger" data-valmsg-for="roomId" data-valmsg-replace="true"></span>
                        </div>

                        <div class="mb-4">
                            <label for="quantity" class="form-label font-weight-bold">Số lượng</label>
                            <input type="number" id="quantity" name="quantity" class="form-control" min="1" value="1" required />
                            <span class="text-danger" data-valmsg-for="quantity" data-valmsg-replace="true"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Bàn giao
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
