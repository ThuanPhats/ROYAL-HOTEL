@model IEnumerable<QLKhachSan.Models.VatTuTieuHao>
@{
    ViewData["Title"] = "Quản lý vật tư tiêu hao";
    var lowStockItems = ViewBag.LowStockItems as IEnumerable<QLKhachSan.Models.VatTuTieuHao>;
    var lowStockIds = lowStockItems?.Select(x => x.Id).ToHashSet() ?? new HashSet<int>();
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h3 class="fw-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
            <i class="fa-solid fa-boxes-stacked text-warning me-2"></i>Vật tư tiêu hao
        </h3>
        <p class="text-muted mb-0 small">Theo dõi tồn kho và cảnh báo vật tư dưới ngưỡng định mức.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm rounded-3">
            <i class="fa-solid fa-arrow-left me-1"></i>Thiết bị
        </a>
        <button type="button" class="btn btn-success rounded-3" data-bs-toggle="modal" data-bs-target="#addConsumableModal">
            <i class="fa-solid fa-plus me-2"></i>Thêm vật tư mới
        </button>
    </div>
</div>

@if (lowStockIds.Any())
{
    <div class="alert alert-warning border-0 rounded-3 shadow-sm d-flex align-items-center gap-3 mb-4" role="alert">
        <i class="fa-solid fa-triangle-exclamation fs-4"></i>
        <div>
            <strong>Cảnh báo!</strong> Có <strong>@lowStockIds.Count</strong> loại vật tư đang dưới ngưỡng tồn kho tối thiểu.
            Vui lòng đặt mua bổ sung.
        </div>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 p-4">
    <div class="table-responsive border rounded-3">
        <table class="table table-hover align-middle mb-0" id="consumablesTable">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Tên vật tư</th>
                    <th class="text-center">ĐVT</th>
                    <th class="text-center">Tồn kho</th>
                    <th class="text-center">Định mức tối thiểu</th>
                    <th class="text-end">Đơn giá nhập</th>
                    <th class="text-center" width="160">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{int stt = 1;}
                @foreach (var item in Model)
                {
                    bool isLow = lowStockIds.Contains(item.Id);
                    string rowClass = isLow ? "table-danger" : "";
                    <tr class="@rowClass">
                        <td class="text-muted small">@stt++</td>
                        <td>
                            <div class="fw-bold">@item.TenVatTu</div>
                            @if (isLow)
                            {
                                <small class="text-danger">
                                    <i class="fa-solid fa-circle-exclamation me-1"></i>Dưới ngưỡng tồn kho!
                                </small>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border">@item.Dvt</span>
                        </td>
                        <td class="text-center">
                            <span class="fw-bold @(isLow ? "text-danger" : "text-success") fs-6">
                                @item.SoLuongTon
                            </span>
                        </td>
                        <td class="text-center text-muted">@item.DinhMucToiThieu</td>
                        <td class="text-end">@item.DonGia.ToString("N0") đ</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-1">
                                <!-- Nhập thêm -->
                                <button class="btn btn-outline-success btn-sm rounded-2"
                                        data-bs-toggle="modal"
                                        data-bs-target="#updateStockModal"
                                        data-id="@item.Id"
                                        data-name="@item.TenVatTu"
                                        title="Nhập kho / Xuất kho">
                                    <i class="fa-solid fa-right-left"></i>
                                </button>
                                <!-- Đề xuất mua sắm -->
                                <form asp-action="ProposePurchase" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <input type="hidden" name="quantity" value="@(item.DinhMucToiThieu * 2)" />
                                    <button type="submit" class="btn btn-outline-warning btn-sm rounded-2" title="Đề xuất mua sắm">
                                        <i class="fa-solid fa-cart-plus"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <i class="fa-solid fa-box-open fs-2 text-secondary mb-3 d-block"></i>
                            Chưa có vật tư nào được quản lý.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="mt-3 small text-muted">
        Tổng: <strong>@Model.Count()</strong> loại vật tư |
        Dưới ngưỡng: <strong class="text-danger">@lowStockIds.Count</strong>
    </div>
</div>

<!-- Modal Thêm vật tư mới -->
<div class="modal fade" id="addConsumableModal" tabindex="-1" aria-labelledby="addConsumableModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <form asp-action="CreateConsumable" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="addConsumableModalLabel">
                        <i class="fa-solid fa-plus me-2"></i>Thêm vật tư tiêu hao
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Tên vật tư *</label>
                        <input type="text" name="TenVatTu" class="form-control" placeholder="Xà phòng, khăn tắm, kem đánh răng..." required />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small">Đơn vị tính *</label>
                            <input type="text" name="Dvt" class="form-control" placeholder="Cái, Hộp, Lít..." required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small">Số lượng tồn ban đầu</label>
                            <input type="number" name="SoLuongTon" class="form-control" value="0" min="0" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small">Định mức tối thiểu</label>
                            <input type="number" name="DinhMucToiThieu" class="form-control" value="10" min="1" />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small">Đơn giá nhập (đ)</label>
                            <input type="number" name="DonGia" class="form-control" value="0" min="0" step="1000" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">
                        <i class="fa-solid fa-plus me-1"></i>Thêm vật tư
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Cập nhật tồn kho -->
<div class="modal fade" id="updateStockModal" tabindex="-1" aria-labelledby="updateStockModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content rounded-4 border-0 shadow">
            <form asp-action="UpdateStock" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="itemId" id="stockItemId" />
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="updateStockModalLabel">
                        <i class="fa-solid fa-right-left me-2"></i>Cập nhật tồn kho
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-3">Vật tư: <strong id="stockItemName"></strong></p>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Thay đổi số lượng *</label>
                        <input type="number" name="changeQty" class="form-control" placeholder="(+) Nhập kho | (-) Xuất kho"
                               value="0" required />
                        <div class="form-text">Nhập số âm để trừ (xuất kho).</div>
                    </div>
                </div>
                <div class="modal-footer border-top-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">Xác nhận</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('[data-bs-target="#updateStockModal"]').forEach(btn => {
            btn.addEventListener('click', function () {
                document.getElementById('stockItemId').value = this.dataset.id;
                document.getElementById('stockItemName').textContent = this.dataset.name;
            });
        });
    </script>
}
