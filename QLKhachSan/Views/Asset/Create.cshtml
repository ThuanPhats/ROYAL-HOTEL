@model QLKhachSan.Models.ThietBi
@{
    ViewData["Title"] = "Thêm thiết bị / Tài sản mới";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 fw-bold" style="font-family: 'Outfit', sans-serif;">
        <a href="@Url.Action("Index")" class="text-decoration-none text-muted">
            <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
        </a> | Thêm thiết bị mới
    </h5>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4 mx-auto" style="max-width: 640px;">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

        <h6 class="fw-bold text-muted text-uppercase mb-3 small">
            <i class="fa-solid fa-microchip me-2"></i>Thông tin thiết bị
        </h6>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="MaTaiSan" class="form-label fw-bold small"></label>
                <input asp-for="MaTaiSan" class="form-control" placeholder="TB001, TV-101..." />
                <span asp-validation-for="MaTaiSan" class="text-danger small"></span>
            </div>
            <div class="col-md-8 mb-3">
                <label asp-for="TenThietBi" class="form-label fw-bold small"></label>
                <input asp-for="TenThietBi" class="form-control" placeholder="Tivi Samsung 55", Điều hòa Daikin..." />
                <span asp-validation-for="TenThietBi" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="LoaiThietBiId" class="form-label fw-bold small">Loại thiết bị *</label>
            <select asp-for="LoaiThietBiId" class="form-select">
                <option value="">-- Chọn loại thiết bị --</option>
                @foreach (var t in ViewBag.AssetTypes)
                {
                    <option value="@t.Id">@t.TenLoai</option>
                }
            </select>
            <span asp-validation-for="LoaiThietBiId" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NhaCungCap" class="form-label fw-bold small"></label>
            <input asp-for="NhaCungCap" class="form-control" placeholder="Công ty TNHH ABC, Samsung Vina..." />
            <span asp-validation-for="NhaCungCap" class="text-danger small"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="NgayMua" class="form-label fw-bold small"></label>
                <input asp-for="NgayMua" class="form-control" type="date" />
                <span asp-validation-for="NgayMua" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="HanBaoHanh" class="form-label fw-bold small"></label>
                <input asp-for="HanBaoHanh" class="form-control" type="date" />
                <span asp-validation-for="HanBaoHanh" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-4">
            <label asp-for="TrangThai" class="form-label fw-bold small">Trạng thái thiết bị *</label>
            <select asp-for="TrangThai" class="form-select">
                <option value="Tot">Tốt – Hoạt động bình thường</option>
                <option value="CanSuaChua">Cần sửa chữa</option>
                <option value="DaThayThe">Đã thay thế</option>
                <option value="ThanhLy">Thanh lý</option>
            </select>
            <span asp-validation-for="TrangThai" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100 py-2">
                <i class="fa-solid fa-plus me-2"></i> THÊM THIẾT BỊ
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary w-50 py-2">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
