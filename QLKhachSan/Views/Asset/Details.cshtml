@model QLKhachSan.Models.ThietBi
@{
    ViewData["Title"] = "Chi tiết thiết bị";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Chi tiết thiết bị</h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil-square me-1"></i>Sửa
            </a>
            <a asp-action="ReportFailure" asp-route-assetId="@Model.Id" class="btn btn-danger">
                <i class="bi bi-exclamation-triangle me-1"></i>Báo hỏng
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Quay lại
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Thông tin thiết bị</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width: 35%">Mã tài sản:</th>
                            <td>@Model.MaTaiSan</td>
                        </tr>
                        <tr>
                            <th>Tên thiết bị:</th>
                            <td>@Model.TenThietBi</td>
                        </tr>
                        <tr>
                            <th>Loại thiết bị:</th>
                            <td>@(Model.LoaiThietBi?.TenLoai ?? "Chưa xác định")</td>
                        </tr>
                        <tr>
                            <th>Ngày mua:</th>
                            <td>@(Model.NgayMua?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</td>
                        </tr>
                        <tr>
                            <th>Nhà cung cấp:</th>
                            <td>@(Model.NhaCungCap ?? "Chưa cập nhật")</td>
                        </tr>
                        <tr>
                            <th>Hạn bảo hành:</th>
                            <td>@(Model.HanBaoHanh?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</td>
                        </tr>
                        <tr>
                            <th>Trạng thái:</th>
                            <td>
                                @switch (Model.TrangThai)
                                {
                                    case "Tot":
                                        <span class="badge bg-success">Hoạt động tốt</span>
                                        break;
                                    case "CanSuaChua":
                                    case "CanSua":
                                        <span class="badge bg-warning text-dark">Cần sửa chữa</span>
                                        break;
                                    case "DaThayThe":
                                        <span class="badge bg-info text-dark">Đã thay thế</span>
                                        break;
                                    case "ThanhLy":
                                        <span class="badge bg-secondary">Đã thanh lý</span>
                                        break;
                                    default:
                                        <span class="badge bg-dark">@Model.TrangThai</span>
                                        break;
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-house-door me-2"></i>Vị trí lắp đặt hiện tại</h5>
                </div>
                <div class="card-body">
                    @if (Model.PhongThietBis != null && Model.PhongThietBis.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Phòng</th>
                                        <th>Ngày bàn giao</th>
                                        <th>Số lượng</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ptb in Model.PhongThietBis)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-controller="Room" asp-action="Details" asp-route-id="@ptb.PhongId">
                                                    Phòng @(ptb.Phong?.MaPhong ?? ptb.PhongId.ToString())
                                                </a>
                                            </td>
                                            <td>@ptb.NgayBanGiao.ToString("dd/MM/yyyy")</td>
                                            <td>@ptb.SoLuong</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            Thiết bị này chưa được phân bổ vào phòng nào (đang lưu kho).
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mt-3">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-wrench-adjacent me-2"></i>Lịch sử bảo trì và sửa chữa</h5>
        </div>
        <div class="card-body">
            @if (Model.LichSuBaoTris != null && Model.LichSuBaoTris.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Ngày báo hỏng</th>
                                <th>Mô tả sự cố</th>
                                <th>Kỹ thuật viên</th>
                                <th>Chi phí</th>
                                <th>Ngày hoàn tất</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.LichSuBaoTris.OrderByDescending(l => l.NgayBaoHong))
                            {
                                <tr>
                                    <td>@log.NgayBaoHong.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@log.MoTaSuCo</td>
                                    <td>@(log.NhanVienKyThuat?.HoTen ?? "Chưa phân công")</td>
                                    <td>@log.ChiPhi.ToString("N0") đ</td>
                                    <td>@(log.NgayHoanTat?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td>
                                        @switch (log.TrangThai)
                                        {
                                            case "DangXuLy":
                                                <span class="badge bg-warning text-dark">Đang xử lý</span>
                                                break;
                                            case "HoanTat":
                                                <span class="badge bg-success">Hoàn tất</span>
                                                break;
                                            case "Huy":
                                                <span class="badge bg-danger">Hủy bỏ</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@log.TrangThai</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-light border text-center mb-0">
                    Không có lịch sử sửa chữa cho thiết bị này.
                </div>
            }
        </div>
    </div>
</div>
