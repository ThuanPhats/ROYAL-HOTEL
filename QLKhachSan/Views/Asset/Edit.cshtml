@model QLKhachSan.Models.ThietBi
@{
    ViewData["Title"] = "Chỉnh sửa thiết bị";
    var assetTypes = ViewBag.AssetTypes as IEnumerable<QLKhachSan.Models.LoaiThietBi> ?? new List<QLKhachSan.Models.LoaiThietBi>();
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa thiết bị</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" asp-antiforgery="true">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="MaTaiSan" class="form-label font-weight-bold"></label>
                            <input asp-for="MaTaiSan" class="form-control bg-light" readonly />
                            <span asp-validation-for="MaTaiSan" class="text-danger"></span>
                            <div class="form-text text-muted">Không được phép sửa mã tài sản.</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TenThietBi" class="form-label font-weight-bold"></label>
                            <input asp-for="TenThietBi" class="form-control" placeholder="Nhập tên thiết bị..." required />
                            <span asp-validation-for="TenThietBi" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LoaiThietBiId" class="form-label font-weight-bold"></label>
                            <select asp-for="LoaiThietBiId" class="form-select" required>
                                <option value="">-- Chọn loại thiết bị --</option>
                                @foreach (var type in assetTypes)
                                {
                                    <option value="@type.Id">@type.TenLoai</option>
                                }
                            </select>
                            <span asp-validation-for="LoaiThietBiId" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="NgayMua" class="form-label font-weight-bold"></label>
                                <input asp-for="NgayMua" class="form-control" type="date" />
                                <span asp-validation-for="NgayMua" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="HanBaoHanh" class="form-label font-weight-bold"></label>
                                <input asp-for="HanBaoHanh" class="form-control" type="date" />
                                <span asp-validation-for="HanBaoHanh" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NhaCungCap" class="form-label font-weight-bold"></label>
                            <input asp-for="NhaCungCap" class="form-control" placeholder="Tên nhà cung cấp..." />
                            <span asp-validation-for="NhaCungCap" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TrangThai" class="form-label font-weight-bold"></label>
                            <select asp-for="TrangThai" class="form-select" required>
                                <option value="Tot">Hoạt động tốt</option>
                                <option value="CanSuaChua">Cần sửa chữa</option>
                                <option value="DaThayThe">Đã thay thế</option>
                                <option value="ThanhLy">Đã thanh lý</option>
                            </select>
                            <span asp-validation-for="TrangThai" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i>Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
