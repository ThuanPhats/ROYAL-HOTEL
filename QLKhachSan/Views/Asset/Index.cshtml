@model IEnumerable<QLKhachSan.Models.ThietBi>
@{
    ViewData["Title"] = "Quản lý trang thiết bị";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h3 class="font-weight-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
                <i class="fa-solid fa-laptop-house text-primary me-2"></i>Quản lý Trang thiết bị & Tài sản
            </h3>
            <p class="text-muted mb-0 small">Danh mục cơ sở vật chất, thiết bị tiện nghi buồng phòng và thiết bị kỹ thuật khách sạn.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("ConsumablesIndex")" class="btn btn-outline-info rounded-3">
                <i class="fa-solid fa-soap me-2"></i>Vật tư tiêu hao
            </a>
            <a href="@Url.Action("MaintenanceIndex")" class="btn btn-outline-danger rounded-3">
                <i class="fa-solid fa-wrench me-2"></i>Nhật ký bảo trì
            </a>
            <a href="@Url.Action("Allocate")" class="btn btn-success rounded-3">
                <i class="fa-solid fa-dolly me-2"></i>Bàn giao vào phòng
            </a>
            @if (User.IsInRole("Admin") || User.IsInRole("QuanLy"))
            {
                <a href="@Url.Action("Create")" class="btn btn-primary rounded-3">
                    <i class="fa-solid fa-plus me-2"></i>Khai báo tài sản
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <!-- Bộ lọc nhanh -->
        <div class="row g-3 mb-4">
            <div class="col-md-6 col-lg-4">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa-solid fa-magnifying-glass"></i></span>
                    <input type="text" id="assetSearch" class="form-control border-start-0 rounded-end-3" placeholder="Tìm kiếm theo mã tài sản, tên thiết bị..." />
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <select id="filterType" class="form-select rounded-3">
                    <option value="">-- Tất cả loại thiết bị --</option>
                    @if (Model != null)
                    {
                        var types = Model.Select(e => e.LoaiThietBi?.TenLoai).Distinct().Where(t => t != null);
                        foreach (var type in types)
                        {
                            <option value="@type">@type</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-6 col-lg-3">
                <select id="filterStatus" class="form-select rounded-3">
                    <option value="">-- Tất cả trạng thái --</option>
                    <option value="Tot">Hoạt động tốt</option>
                    <option value="CanSuaChua">Cần sửa chữa</option>
                    <option value="DaThayTe">Đã thay thế</option>
                    <option value="ThanhLy">Đã thanh lý</option>
                </select>
            </div>
        </div>

        <div class="table-responsive border rounded-3">
            <table class="table table-hover align-middle mb-0" id="assetsTable">
                <thead class="table-light">
                    <tr>
                        <th width="120">Mã tài sản</th>
                        <th>Tên tài sản / Thiết bị</th>
                        <th>Loại thiết bị</th>
                        <th>Nhà cung cấp / Mua</th>
                        <th class="text-center">Hạn bảo hành</th>
                        <th class="text-center">Trạng thái</th>
                        <th width="150" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        string statusBadge = "";
                        string statusText = "";
                        switch (item.TrangThai)
                        {
                            case "Tot": 
                                statusBadge = "bg-success"; 
                                statusText = "Hoạt động tốt"; 
                                break;
                            case "CanSuaChua": 
                                statusBadge = "bg-danger"; 
                                statusText = "Cần sửa chữa"; 
                                break;
                            case "DaThayTe": 
                                statusBadge = "bg-warning text-dark"; 
                                statusText = "Đã thay thế"; 
                                break;
                            case "ThanhLy": 
                                statusBadge = "bg-secondary"; 
                                statusText = "Đã thanh lý"; 
                                break;
                            default:
                                statusBadge = "bg-dark";
                                statusText = item.TrangThai;
                                break;
                        }

                        <tr class="asset-row" data-search="@(item.MaTaiSan.ToLower() + " " + item.TenThietBi.ToLower())" data-type="@(item.LoaiThietBi?.TenLoai ?? "")" data-status="@item.TrangThai">
                            <td class="font-monospace text-secondary font-weight-bold">@item.MaTaiSan</td>
                            <td>
                                <strong class="text-dark">@item.TenThietBi</strong>
                                @if (item.PhongThietBis != null && item.PhongThietBis.Any())
                                {
                                    <div class="small text-muted font-italic">
                                        <i class="fa-solid fa-door-closed me-1"></i> Đang phân bổ tại: 
                                        @string.Join(", ", item.PhongThietBis.Select(pt => $"P.{pt.Phong?.MaPhong} (x{pt.SoLuong})"))
                                    </div>
                                }
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">@(item.LoaiThietBi?.TenLoai ?? "N/A")</span>
                            </td>
                            <td>
                                <div class="small">@item.NhaCungCap</div>
                                <div class="small text-muted">Mua ngày: @(item.NgayMua?.ToString("dd/MM/yyyy") ?? "N/A")</div>
                            </td>
                            <td class="text-center text-muted small">
                                @if (item.HanBaoHanh.HasValue)
                                {
                                    bool isExpired = item.HanBaoHanh.Value < DateTime.Today;
                                    string textClass = isExpired ? "text-danger font-weight-bold" : "";
                                    <span class="@textClass">@item.HanBaoHanh.Value.ToString("dd/MM/yyyy")</span>
                                }
                                else
                                {
                                    <span>N/A</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge @statusBadge rounded-pill px-3 py-2">@statusText</span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-outline-primary btn-sm rounded-2" title="Chi tiết">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-outline-warning btn-sm rounded-2" title="Chỉnh sửa">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("QuanLy"))
                                    {
                                        <form asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa thiết bị này khỏi danh sách?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-2" title="Xóa">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (item.TrangThai == "Tot")
                                    {
                                        <button class="btn btn-outline-danger btn-sm rounded-2 btn-report-failure" data-id="@item.Id" data-name="@item.TenThietBi" title="Báo hỏng / Cần bảo trì">
                                            <i class="fa-solid fa-triangle-exclamation"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <i class="fa-solid fa-box-archive fs-2 text-secondary mb-3 d-block"></i>
                                Không có thiết bị nào trong danh mục.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Báo Hỏng Bảo Trì -->
<div class="modal fade" id="reportFailureModal" tabindex="-1" aria-labelledby="reportFailureModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <form asp-action="ReportFailure" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="assetId" id="reportAssetId" />
                <input type="hidden" name="employeeId" value="1" /> <!-- Tạm thời gán nhân viên báo hỏng ID = 1 -->
                
                <div class="modal-header">
                    <h5 class="modal-title font-weight-bold" id="reportFailureModalLabel">Báo hỏng thiết bị & Đề xuất bảo trì</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted">Thiết bị: <strong id="reportAssetName" class="text-dark"></strong> sẽ được đánh dấu trạng thái <span class="badge bg-danger">Cần sửa chữa</span> và chuyển thông tin sang Tổ Kỹ thuật.</p>
                    <div class="mb-3">
                        <label for="problem" class="form-label font-weight-bold small text-muted">Mô tả chi tiết sự cố:</label>
                        <textarea name="problem" id="problem" class="form-control rounded-3" rows="3" placeholder="Ví dụ: Máy điều hòa không lạnh, có tiếng kêu to ở dàn nóng..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">Xác nhận báo sự cố</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Live Search and Filters
            $('#assetSearch, #filterType, #filterStatus').on('keyup change', function () {
                let searchVal = $('#assetSearch').val().toLowerCase();
                let typeVal = $('#filterType').val();
                let statusVal = $('#filterStatus').val();

                $('.asset-row').each(function () {
                    let searchData = $(this).data('search');
                    let typeData = $(this).data('type');
                    let statusData = $(this).data('status');

                    let matchesSearch = searchData.indexOf(searchVal) > -1;
                    let matchesType = typeVal === "" || typeData === typeVal;
                    let matchesStatus = statusVal === "" || statusData === statusVal;

                    if (matchesSearch && matchesType && matchesStatus) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            });

            // Report Failure Modal triggering
            $('.btn-report-failure').on('click', function () {
                let id = $(this).data('id');
                let name = $(this).data('name');

                $('#reportAssetId').val(id);
                $('#reportAssetName').text(name);

                let myModal = new bootstrap.Modal(document.getElementById('reportFailureModal'));
                myModal.show();
            });
        });
    </script>
}
