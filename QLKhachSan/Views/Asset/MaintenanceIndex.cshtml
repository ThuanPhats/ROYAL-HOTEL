@model IEnumerable<QLKhachSan.Models.LichSuBaoTri>
@{
    ViewData["Title"] = "Lịch sử bảo trì thiết bị";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h3 class="fw-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
            <i class="fa-solid fa-screwdriver-wrench text-danger me-2"></i>Lịch sử bảo trì
        </h3>
        <p class="text-muted mb-0 small">Nhật ký sự cố và bảo trì thiết bị trong khách sạn.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm rounded-3">
            <i class="fa-solid fa-arrow-left me-1"></i>Thiết bị
        </a>
        <a href="@Url.Action("ReportFailure")" class="btn btn-danger rounded-3">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>Báo hỏng thiết bị
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 p-4">
    <!-- Bộ lọc -->
    <div class="row mb-3">
        <div class="col-md-4">
            <select id="statusFilter" class="form-select form-select-sm">
                <option value="">Tất cả trạng thái</option>
                <option value="DangXuLy">Đang xử lý</option>
                <option value="HoanTat">Hoàn tất</option>
                <option value="Huy">Đã hủy</option>
            </select>
        </div>
    </div>

    <div class="table-responsive border rounded-3">
        <table class="table table-hover align-middle mb-0" id="maintenanceTable">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Thiết bị</th>
                    <th>Mô tả sự cố</th>
                    <th>Ngày báo hỏng</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-end">Chi phí</th>
                    <th>Ngày hoàn tất</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center" width="120">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{int stt = 1;}
                @foreach (var item in Model.OrderByDescending(m => m.NgayBaoHong))
                {
                    <tr data-status="@item.TrangThai">
                        <td class="text-muted small">@stt++</td>
                        <td>
                            <div class="fw-bold small">@item.ThietBi?.TenThietBi</div>
                            <small class="text-muted font-monospace">@item.ThietBi?.MaTaiSan</small>
                        </td>
                        <td>
                            <span class="text-secondary small">@item.MoTaSuCo</span>
                        </td>
                        <td class="small text-muted">@item.NgayBaoHong.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="small">
                            @if (item.NhanVienKyThuat != null)
                            {
                                <span><i class="fa-solid fa-user me-1 text-muted"></i>@item.NhanVienKyThuat.HoTen</span>
                            }
                            else
                            {
                                <span class="text-muted">Chưa phân công</span>
                            }
                        </td>
                        <td class="text-end small fw-bold">
                            @if (item.ChiPhi > 0)
                            {
                                @item.ChiPhi.ToString("N0")<span class="text-muted"> đ</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="small text-muted">
                            @(item.NgayHoanTat.HasValue ? item.NgayHoanTat.Value.ToString("dd/MM/yyyy") : "—")
                        </td>
                        <td class="text-center">
                            @{
                                string statusBadge = item.TrangThai switch
                                {
                                    "HoanTat" => "bg-success",
                                    "Huy" => "bg-secondary",
                                    _ => "bg-warning text-dark"
                                };
                                string statusText = item.TrangThai switch
                                {
                                    "DangXuLy" => "Đang xử lý",
                                    "HoanTat" => "Hoàn tất",
                                    "Huy" => "Đã hủy",
                                    _ => item.TrangThai
                                };
                            }
                            <span class="badge @statusBadge rounded-pill px-3 py-1">@statusText</span>
                        </td>
                        <td class="text-center">
                            @if (item.TrangThai == "DangXuLy")
                            {
                                <button class="btn btn-outline-success btn-sm rounded-2"
                                        data-bs-toggle="modal"
                                        data-bs-target="#completeModal"
                                        data-logid="@item.Id"
                                        data-name="@item.ThietBi?.TenThietBi"
                                        title="Đánh dấu hoàn tất">
                                    <i class="fa-solid fa-check"></i>
                                </button>
                            }
                            <a href="@Url.Action("Details", new { id = item.ThietBiId })"
                               class="btn btn-outline-primary btn-sm rounded-2 ms-1" title="Chi tiết thiết bị">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-5">
                            <i class="fa-solid fa-wrench fs-2 text-secondary mb-3 d-block"></i>
                            Chưa có lịch sử bảo trì nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="mt-3 small text-muted">
        Tổng: <strong>@Model.Count()</strong> bản ghi |
        Đang xử lý: <strong class="text-warning">@Model.Count(m => m.TrangThai == "DangXuLy")</strong> |
        Hoàn tất: <strong class="text-success">@Model.Count(m => m.TrangThai == "HoanTat")</strong>
    </div>
</div>

<!-- Modal Hoàn tất bảo trì -->
<div class="modal fade" id="completeModal" tabindex="-1" aria-labelledby="completeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <form asp-action="CompleteMaintenance" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="logId" id="completeLogId" />
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="completeModalLabel">
                        <i class="fa-solid fa-check-circle me-2 text-success"></i>Hoàn tất sửa chữa
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted">Thiết bị: <strong id="completeDeviceName"></strong></p>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Chi phí sửa chữa (đ)</label>
                        <input type="number" name="cost" class="form-control" min="0" step="10000" value="0" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Ghi chú</label>
                        <textarea name="notes" class="form-control" rows="3" placeholder="Mô tả công việc đã thực hiện..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">
                        <i class="fa-solid fa-check me-1"></i>Xác nhận hoàn tất
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Lọc theo trạng thái
        document.getElementById('statusFilter').addEventListener('change', function () {
            const val = this.value;
            document.querySelectorAll('#maintenanceTable tbody tr[data-status]').forEach(row => {
                row.style.display = (!val || row.dataset.status === val) ? '' : 'none';
            });
        });

        // Modal hoàn tất
        document.querySelectorAll('[data-bs-target="#completeModal"]').forEach(btn => {
            btn.addEventListener('click', function () {
                document.getElementById('completeLogId').value = this.dataset.logid;
                document.getElementById('completeDeviceName').textContent = this.dataset.name;
            });
        });
    </script>
}
