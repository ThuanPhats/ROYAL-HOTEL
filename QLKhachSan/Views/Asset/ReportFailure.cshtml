@model dynamic
@{
    ViewData["Title"] = "Báo hỏng thiết bị";
    var assets = ViewBag.Assets as IEnumerable<QLKhachSan.Models.ThietBi> ?? new List<QLKhachSan.Models.ThietBi>();
    var employees = ViewBag.Employees as IEnumerable<QLKhachSan.Models.NhanVien> ?? new List<QLKhachSan.Models.NhanVien>();
    
    // Check if assetId is passed in the query string
    string queryAssetId = Context.Request.Query["assetId"];
    int selectedAssetId = 0;
    int.TryParse(queryAssetId, out selectedAssetId);
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Báo cáo sự cố thiết bị</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ReportFailure" method="post" asp-antiforgery="true">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        @if (selectedAssetId > 0)
                        {
                            var selectedAsset = assets.FirstOrDefault(a => a.Id == selectedAssetId);
                            if (selectedAsset != null)
                            {
                                <div class="mb-3">
                                    <label class="form-label font-weight-bold">Thiết bị báo hỏng</label>
                                    <input type="text" class="form-control bg-light" value="@selectedAsset.TenThietBi (@selectedAsset.MaTaiSan)" readonly />
                                    <input type="hidden" name="assetId" value="@selectedAssetId" />
                                </div>
                            }
                            else
                            {
                                <div class="mb-3">
                                    <label for="assetId" class="form-label font-weight-bold">Chọn thiết bị báo hỏng</label>
                                    <select id="assetId" name="assetId" class="form-select" required>
                                        <option value="">-- Chọn thiết bị --</option>
                                        @foreach (var asset in assets)
                                        {
                                            <option value="@asset.Id">@asset.TenThietBi (@asset.MaTaiSan)</option>
                                        }
                                    </select>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="mb-3">
                                <label for="assetId" class="form-label font-weight-bold">Chọn thiết bị báo hỏng</label>
                                <select id="assetId" name="assetId" class="form-select" required>
                                    <option value="">-- Chọn thiết bị --</option>
                                    @foreach (var asset in assets)
                                    {
                                        <option value="@asset.Id">@asset.TenThietBi (@asset.MaTaiSan)</option>
                                    }
                                </select>
                            </div>
                        }

                        <div class="mb-3">
                            <label for="problem" class="form-label font-weight-bold">Mô tả sự cố / Lý do hỏng</label>
                            <textarea id="problem" name="problem" class="form-control" rows="4" placeholder="Mô tả chi tiết tình trạng hỏng hóc..." required></textarea>
                            <div class="form-text">Vui lòng cung cấp chi tiết lỗi để kỹ thuật viên dễ dàng xử lý.</div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label for="employeeId" class="form-label font-weight-bold">Người báo cáo</label>
                                <select id="employeeId" name="employeeId" class="form-select" required>
                                    <option value="">-- Chọn nhân viên --</option>
                                    @foreach (var emp in employees)
                                    {
                                        // Simple heuristic to pre-select logged in user if match by name/email
                                        bool isSelected = User.Identity?.Name == emp.Email || User.Identity?.Name == emp.MaNV;
                                        <!option value="@emp.Id" @(isSelected ? "selected" : "")>@emp.HoTen (@emp.MaNV)</!option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label font-weight-bold">Ngày báo cáo</label>
                                <input type="text" class="form-control bg-light" value="@DateTime.Now.ToString("dd/MM/yyyy")" readonly />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            @if (selectedAssetId > 0)
                            {
                                <a asp-action="Details" asp-route-id="@selectedAssetId" class="btn btn-outline-secondary">
                                    <i class="bi bi-x-circle me-1"></i>Hủy bỏ
                                </a>
                            }
                            else
                            {
                                <a asp-action="Index" class="btn btn-outline-secondary">
                                    <i class="bi bi-x-circle me-1"></i>Hủy bỏ
                                </a>
                            }
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-exclamation-triangle me-1"></i>Gửi yêu cầu sửa chữa
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
