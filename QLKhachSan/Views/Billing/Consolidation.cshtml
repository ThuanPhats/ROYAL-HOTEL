@{
    ViewData["Title"] = "Gộp hóa đơn Master Folio";
    var activeFolios = ViewBag.ActiveFolios as IEnumerable<QLKhachSan.Models.PhieuLuuTru>;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h3 class="fw-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
            <i class="fa-solid fa-layer-group text-primary me-2"></i>Gộp hóa đơn (Master Folio)
        </h3>
        <p class="text-muted mb-0 small">Gộp nhiều phiếu lưu trú của đoàn khách vào một phiếu thanh toán chung.</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-3">
        <i class="fa-solid fa-arrow-left me-2"></i>Về danh sách hóa đơn
    </a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="fa-solid fa-circle-xmark me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="Consolidation" method="post" id="consolidationForm">
    @Html.AntiForgeryToken()
    <div class="row g-4">
        <!-- Cột trái: danh sách Folio -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                    <h6 class="fw-bold text-uppercase text-muted small">
                        <i class="fa-solid fa-list-check me-2"></i>
                        Chọn các Folio con cần gộp
                    </h6>
                    <p class="small text-muted mb-0">Tích chọn các phiếu lưu trú bạn muốn gộp vào Folio Master.</p>
                </div>
                <div class="card-body px-4">
                    @if (activeFolios != null && activeFolios.Any())
                    {
                        <div class="table-responsive border rounded-3">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th width="40">
                                            <input type="checkbox" class="form-check-input" id="selectAll" title="Chọn tất cả" />
                                        </th>
                                        <th>Mã Folio</th>
                                        <th>Khách đại diện</th>
                                        <th>Phòng</th>
                                        <th>Ngày nhận phòng</th>
                                        <th class="text-center">Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var folio in activeFolios)
                                    {
                                        <tr class="folio-row">
                                            <td>
                                                <input type="checkbox" class="form-check-input folio-check"
                                                       name="childFolioIds"
                                                       value="@folio.Id"
                                                       data-total="0" />
                                            </td>
                                            <td>
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-2 fw-bold">
                                                    @folio.MaFolio
                                                </span>
                                            </td>
                                            <td>
                                                <div class="fw-bold small">@folio.KhachHang?.HoTen</div>
                                                <small class="text-muted">@(folio.KhachHang?.Sdt ?? "")</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border">@folio.Phong?.MaPhong</span>
                                            </td>
                                            <td class="small text-muted">
                                                @folio.NgayCheckInAct.ToString("dd/MM/yyyy HH:mm")
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-success rounded-pill">Đang lưu trú</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fa-solid fa-bed fs-2 mb-3 d-block text-secondary"></i>
                            Không có phiếu lưu trú nào đang hoạt động.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Cột phải: chọn Master Folio & tổng kết -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                    <h6 class="fw-bold text-uppercase text-muted small">
                        <i class="fa-solid fa-crown me-2 text-warning"></i>Folio Master (nhận gộp)
                    </h6>
                </div>
                <div class="card-body px-4">
                    <label class="form-label fw-bold small">Chọn Folio Master *</label>
                    <select name="masterFolioId" class="form-select" id="masterFolioSelect" required>
                        <option value="">-- Chọn Folio Master --</option>
                        @if (activeFolios != null)
                        {
                            @foreach (var folio in activeFolios)
                            {
                                <option value="@folio.Id">@folio.MaFolio — @folio.KhachHang?.HoTen</option>
                            }
                        }
                    </select>
                    <div class="form-text">Folio này sẽ là phiếu thanh toán tổng hợp cho toàn bộ đoàn.</div>
                </div>
            </div>

            <!-- Tổng kết -->
            <div class="card border-0 bg-primary text-white rounded-4 shadow">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-white-50 text-uppercase small mb-3">
                        <i class="fa-solid fa-calculator me-2"></i>Tổng tiền gộp
                    </h6>
                    <div class="mb-2 small">
                        Số Folio đã chọn: <strong id="selectedCount">0</strong>
                    </div>
                    <div class="fs-4 fw-bold" id="totalAmount">0 đ</div>
                    <div class="small text-white-50 mt-1">(Tổng tiền chưa bao gồm thuế VAT)</div>
                </div>
                <div class="card-footer bg-transparent border-0 px-4 pb-4">
                    <button type="submit" class="btn btn-light w-100 py-2 fw-bold"
                            onclick="return validateConsolidation();">
                        <i class="fa-solid fa-layer-group me-2 text-primary"></i>
                        GỘP HÓA ĐƠN
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        // Chọn tất cả
        document.getElementById('selectAll').addEventListener('change', function () {
            document.querySelectorAll('.folio-check').forEach(cb => {
                cb.checked = this.checked;
            });
            updateSummary();
        });

        // Cập nhật tổng khi thay đổi checkbox
        document.querySelectorAll('.folio-check').forEach(cb => {
            cb.addEventListener('change', updateSummary);
        });

        function updateSummary() {
            const checks = document.querySelectorAll('.folio-check:checked');
            document.getElementById('selectedCount').textContent = checks.length;
            // Nếu có dữ liệu tổng tiền, cộng vào (hiện tại dùng placeholder)
            document.getElementById('totalAmount').textContent = checks.length > 0
                ? checks.length + ' phòng được chọn'
                : '0 đ';
        }

        function validateConsolidation() {
            const checks = document.querySelectorAll('.folio-check:checked');
            const master = document.getElementById('masterFolioSelect').value;
            if (checks.length === 0) {
                alert('Vui lòng chọn ít nhất một Folio con để gộp.');
                return false;
            }
            if (!master) {
                alert('Vui lòng chọn Folio Master.');
                return false;
            }
            return confirm('Xác nhận gộp ' + checks.length + ' Folio vào Folio Master đã chọn?');
        }
    </script>
}
