@model QLKhachSan.Models.PhieuLuuTru
@{
    ViewData["Title"] = "Xuất hóa đơn điện tử VAT";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 font-weight-bold" style="font-family: 'Outfit', sans-serif;">
        <a href="@Url.Action("FolioDetails", "CheckInCheckOut", new { id = Model.Id })" class="text-decoration-none text-muted"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại Folio</a> | Xuất hóa đơn điện tử VAT
    </h5>
</div>

<div class="row g-4">
    <!-- Cột trái: Nhập thông tin Công ty xuất hoá đơn -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
            <h5 class="font-weight-bold mb-4" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-file-invoice-dollar text-primary me-2"></i>Thông tin doanh nghiệp mua hàng</h5>
            
            <form asp-action="CreateVAT" method="post">
                <input type="hidden" name="folioId" value="@Model.Id" />

                <!-- Mã số thuế -->
                <div class="mb-3">
                    <label for="mst" class="form-label font-weight-bold small">Mã số thuế (MST) *</label>
                    <input type="text" name="mst" id="mst" class="form-control" placeholder="Nhập mã số thuế doanh nghiệp..." value="@Model.KhachHang?.MstCongTy" required />
                </div>

                <!-- Tên công ty -->
                <div class="mb-3">
                    <label for="companyName" class="form-label font-weight-bold small">Tên công ty / Doanh nghiệp *</label>
                    <input type="text" name="companyName" id="companyName" class="form-control" placeholder="Nhập tên đầy đủ của công ty..." value="@Model.KhachHang?.TenCongTy" required />
                </div>

                <!-- Địa chỉ công ty -->
                <div class="mb-3">
                    <label for="companyAddress" class="form-label font-weight-bold small">Địa chỉ công ty *</label>
                    <input type="text" name="companyAddress" id="companyAddress" class="form-control" placeholder="Nhập địa chỉ đăng ký thuế..." value="@Model.KhachHang?.DiaChiCongTy" required />
                </div>

                <!-- Thuế suất -->
                <div class="mb-4">
                    <label for="taxRate" class="form-label font-weight-bold small">Thuế suất gia tăng (VAT) *</label>
                    <select name="taxRate" id="taxRate" class="form-select border-2 border-primary" required>
                        <option value="0.08">8% (Thuế VAT ưu đãi dịch vụ du lịch/ăn uống)</option>
                        <option value="0.10">10% (Thuế VAT tiêu chuẩn)</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary-custom w-100 py-3 font-weight-bold">
                    <i class="fa-solid fa-cloud-arrow-up me-2"></i> PHÁT HÀNH HÓA ĐƠN VAT ĐIỆN TỬ
                </button>
            </form>
        </div>
    </div>

    <!-- Cột phải: Xem trước Folio giá trị -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-light">
            <h5 class="font-weight-bold mb-3" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-receipt text-primary me-2"></i>Giá trị hóa đơn trước thuế</h5>
            
            <div class="mb-3 border-bottom pb-2">
                <span class="text-muted small">Khách đại diện mua:</span>
                <div class="font-weight-bold fs-5 text-dark">@Model.KhachHang?.HoTen</div>
                <small class="text-muted">CCCD: @Model.KhachHang?.CccdPassport</small>
            </div>

            <!-- Tóm tắt các dòng hàng -->
            <div class="mb-3 border-bottom pb-2">
                <span class="text-muted small mb-2 d-block">Các hạng mục xuất hóa đơn:</span>
                <ul class="list-group list-group-flush mb-0 small bg-transparent">
                    @foreach (var item in Model.ChiTietFolios)
                    {
                        <li class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center bg-transparent">
                            <span>@item.NoiDung (x@item.SoLuong)</span>
                            <span class="font-weight-bold">@item.ThanhTien.ToString("N0") đ</span>
                        </li>
                    }
                </ul>
            </div>

            <div class="text-end">
                @{
                    decimal beforeTax = Model.ChiTietFolios.Sum(c => c.ThanhTien) - Model.GiamTru;
                    if (beforeTax < 0) beforeTax = 0;
                }
                <span class="text-muted small">Cộng tiền dịch vụ (Trước thuế):</span>
                <div class="fs-4 font-weight-bold text-success">@beforeTax.ToString("N0") đ</div>
                <small class="text-muted">Tổng thuế VAT sẽ tự động tính thêm 8% hoặc 10% dựa trên lựa chọn thuế suất.</small>
            </div>
        </div>
    </div>
</div>
