@model IEnumerable<QLKhachSan.Models.HoaDon>
@{
    ViewData["Title"] = "Quản lý hóa đơn VAT";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h3 class="font-weight-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
                <i class="fa-solid fa-receipt text-primary me-2"></i>Sổ hóa đơn điện tử VAT
            </h3>
            <p class="text-muted mb-0 small">Danh sách các hóa đơn điện tử GTGT đã xuất cho khách lưu trú hoặc doanh nghiệp đoàn lữ hành.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Consolidation")" class="btn btn-outline-primary rounded-3">
                <i class="fa-solid fa-object-group me-2"></i>Gộp Folio (Consolidation)
            </a>
            <a href="@Url.Action("Index", "CheckInCheckOut")" class="btn btn-primary rounded-3">
                <i class="fa-solid fa-file-invoice-dollar me-2"></i>Lập hóa đơn mới từ Folio
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <!-- Bộ lọc nhanh -->
        <div class="row g-3 mb-4">
            <div class="col-md-6 col-lg-5">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa-solid fa-magnifying-glass"></i></span>
                    <input type="text" id="invoiceSearch" class="form-control border-start-0 rounded-end-3" placeholder="Tìm theo số HĐ, tên khách, tên công ty, mã số thuế..." />
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <select id="filterType" class="form-select rounded-3">
                    <option value="">-- Tất cả loại hóa đơn --</option>
                    <option value="e-invoice">Hóa đơn điện tử (e-Invoice)</option>
                    <option value="paper">Hóa đơn thường</option>
                </select>
            </div>
        </div>

        <div class="table-responsive border rounded-3">
            <table class="table table-hover align-middle mb-0" id="invoicesTable">
                <thead class="table-light">
                    <tr>
                        <th width="120" class="text-center">Số hóa đơn</th>
                        <th>Ngày xuất bản</th>
                        <th>Khách hàng / Doanh nghiệp</th>
                        <th class="text-end">Tiền trước thuế</th>
                        <th class="text-center">Thuế suất</th>
                        <th class="text-end">Tiền thuế (VAT)</th>
                        <th class="text-end">Tổng tiền (gồm thuế)</th>
                        <th width="100" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderByDescending(h => h.NgayXuat))
                    {
                        decimal preTax = item.TongTien - item.TienThue;
                        
                        <tr class="invoice-row" data-search="@(item.SoHoaDon.ToLower() + " " + item.KhachHang?.HoTen.ToLower() + " " + (item.TenCongTy?.ToLower() ?? "") + " " + (item.MST ?? ""))" data-type="@(item.IsEInvoice ? "e-invoice" : "paper")">
                            <td class="text-center font-monospace text-primary font-weight-bold">
                                @item.SoHoaDon
                            </td>
                            <td class="small text-muted">@item.NgayXuat.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div><strong class="text-dark">@item.KhachHang?.HoTen</strong></div>
                                @if (!string.IsNullOrEmpty(item.TenCongTy))
                                {
                                    <div class="small text-muted">
                                        <i class="fa-solid fa-building me-1"></i> @item.TenCongTy
                                        @if (!string.IsNullOrEmpty(item.MST))
                                        {
                                            <span>(MST: @item.MST)</span>
                                        }
                                    </div>
                                }
                            </td>
                            <td class="text-end text-muted small">@preTax.ToString("N0") đ</td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">@((item.ThueSuat * 100).ToString("N0"))%</span>
                            </td>
                            <td class="text-end text-danger small">@item.TienThue.ToString("N0") đ</td>
                            <td class="text-end font-weight-bold text-dark fs-6">
                                @item.TongTien.ToString("N0") đ
                            </td>
                            <td class="text-center">
                                <a href="@Url.Action("InvoiceDetails", new { id = item.Id })" class="btn btn-outline-primary btn-sm rounded-2 px-3">
                                    <i class="fa-solid fa-receipt me-1"></i> Xem
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="fa-solid fa-file-invoice-dollar fs-2 text-secondary mb-3 d-block"></i>
                                Sổ hóa đơn hiện đang trống.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Live Search and Filters
            $('#invoiceSearch, #filterType').on('keyup change', function () {
                let searchVal = $('#invoiceSearch').val().toLowerCase();
                let typeVal = $('#filterType').val();

                $('.invoice-row').each(function () {
                    let searchData = $(this).data('search');
                    let typeData = $(this).data('type');

                    let matchesSearch = searchData.indexOf(searchVal) > -1;
                    let matchesType = typeVal === "" || typeData === typeVal;

                    if (matchesSearch && matchesType) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            });
        });
    </script>
}
