@model QLKhachSan.Models.HoaDon
@{
    ViewData["Title"] = "Chi tiết hóa đơn VAT — " + Model.SoHoaDon;
    decimal tongChuaThue = Model.ChiTietHoaDons.Sum(c => c.ThanhTien);
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 fw-bold" style="font-family: 'Outfit', sans-serif;">
        <a href="@Url.Action("Index")" class="text-decoration-none text-muted">
            <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
        </a> | Chi tiết hóa đơn VAT
    </h5>
    <div class="d-flex gap-2">
        <button onclick="window.print();" class="btn btn-outline-secondary btn-sm rounded-3">
            <i class="fa-solid fa-print me-2"></i>In hóa đơn
        </button>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mx-auto" id="invoicePrint" style="max-width: 800px;">
    <!-- Header hóa đơn -->
    <div class="card-header bg-primary text-white rounded-top-4 py-4 px-5">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h4 class="fw-bold mb-1" style="font-family: 'Outfit', sans-serif;">
                    <i class="fa-solid fa-hotel me-2"></i>KHÁCH SẠN
                </h4>
                <div class="small text-white-75 opacity-75">Hệ thống quản lý khách sạn chuyên nghiệp</div>
            </div>
            <div class="text-end">
                <div class="badge bg-white text-primary fs-6 px-4 py-2 rounded-3 fw-bold">
                    HÓA ĐƠN VAT
                </div>
                <div class="mt-2 small opacity-75">
                    Số HĐ: <strong>@Model.SoHoaDon</strong>
                </div>
                <div class="small opacity-75">
                    Ngày xuất: @Model.NgayXuat.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>
        </div>
    </div>

    <div class="card-body px-5 py-4">
        <!-- Thông tin hai bên -->
        <div class="row mb-4">
            <div class="col-md-6">
                <h6 class="fw-bold text-muted text-uppercase small mb-2">Người bán</h6>
                <div class="fw-bold text-dark">KHÁCH SẠN ABC</div>
                <div class="small text-muted">123 Nguyễn Huệ, Q.1, TP.HCM</div>
                <div class="small text-muted">MST: 0301234567</div>
            </div>
            <div class="col-md-6">
                <h6 class="fw-bold text-muted text-uppercase small mb-2">Người mua</h6>
                <div class="fw-bold text-dark">@Model.KhachHang?.HoTen</div>
                @if (!string.IsNullOrEmpty(Model.TenCongTy))
                {
                    <div class="small text-muted">Công ty: @Model.TenCongTy</div>
                    <div class="small text-muted">MST: @(Model.MST ?? "N/A")</div>
                    <div class="small text-muted">Địa chỉ: @(Model.DiaChiCongTy ?? "N/A")</div>
                }
                else
                {
                    <div class="small text-muted">CCCD/Passport: @Model.KhachHang?.CccdPassport</div>
                    <div class="small text-muted">SĐT: @(Model.KhachHang?.Sdt ?? "N/A")</div>
                }
            </div>
        </div>

        <hr class="my-3" />

        <!-- Chi tiết dịch vụ -->
        <h6 class="fw-bold text-muted text-uppercase small mb-3">
            <i class="fa-solid fa-list me-2"></i>Chi tiết dịch vụ
        </h6>
        <div class="table-responsive border rounded-3 mb-4">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Tên dịch vụ / Hạng mục</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @{int stt = 1;}
                    @foreach (var ct in Model.ChiTietHoaDons)
                    {
                        <tr>
                            <td class="text-muted small">@stt++</td>
                            <td class="fw-bold small">@ct.TenMuc</td>
                            <td class="text-center">@ct.SoLuong</td>
                            <td class="text-end small">@ct.DonGia.ToString("N0") đ</td>
                            <td class="text-end fw-bold">@ct.ThanhTien.ToString("N0") đ</td>
                        </tr>
                    }
                    @if (!Model.ChiTietHoaDons.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">Không có chi tiết hóa đơn.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Tổng cộng -->
        <div class="d-flex justify-content-end">
            <div style="min-width: 320px;">
                <div class="d-flex justify-content-between mb-2 small text-muted">
                    <span>Cộng tiền hàng (chưa VAT):</span>
                    <span class="fw-bold text-dark">@tongChuaThue.ToString("N0") đ</span>
                </div>
                <div class="d-flex justify-content-between mb-2 small text-muted">
                    <span>Thuế suất VAT:</span>
                    <span class="fw-bold text-dark">@((Model.ThueSuat * 100).ToString("0.#"))%</span>
                </div>
                <div class="d-flex justify-content-between mb-2 small text-muted">
                    <span>Tiền thuế VAT:</span>
                    <span class="fw-bold text-dark">@Model.TienThue.ToString("N0") đ</span>
                </div>
                <hr class="my-2" />
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold fs-6">TỔNG CỘNG:</span>
                    <span class="fw-bold fs-5 text-primary">@Model.TongTien.ToString("N0") đ</span>
                </div>
            </div>
        </div>

        <hr class="my-4" />

        <!-- Thông tin bổ sung -->
        <div class="row">
            <div class="col-md-6">
                <div class="small text-muted">
                    <i class="fa-solid fa-file-invoice me-1"></i>
                    Hình thức: <strong>@(Model.IsEInvoice ? "Hóa đơn điện tử" : "Hóa đơn giấy")</strong>
                </div>
            </div>
            <div class="col-md-6 text-end">
                @{
                    string statusInv = "bg-warning text-dark";
                    string statusText = "Chưa thanh toán";
                    if (Model.PhieuLuuTru?.TrangThai == "DaThanhToan")
                    {
                        statusInv = "bg-success";
                        statusText = "Đã thanh toán";
                    }
                }
                <span class="badge @statusInv fs-6 px-4 py-2 rounded-3">@statusText</span>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .btn, nav, .sidebar, footer { display: none !important; }
        #invoicePrint { box-shadow: none !important; border: 1px solid #ddd !important; }
    }
</style>
