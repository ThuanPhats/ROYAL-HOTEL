@model QLKhachSan.Models.PhieuDatPhong
@{
    ViewData["Title"] = "Đặt phòng mới";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 font-weight-bold" style="font-family: 'Outfit', sans-serif;">
        <a href="@Url.Action("Index")" class="text-decoration-none text-muted"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a> | Đặt phòng mới
    </h5>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
    <form asp-action="Create" method="post" id="bookingForm">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="row g-3 mb-4">
            <!-- Khách hàng đại diện -->
            <div class="col-md-4">
                <label asp-for="KhachHangId" class="form-label font-weight-bold small">Khách hàng đại diện *</label>
                <select asp-for="KhachHangId" class="form-select" required>
                    <option value="">-- Chọn khách hàng --</option>
                    @foreach (var c in ViewBag.KhachHangs)
                    {
                        <option value="@c.Id">@c.HoTen (@c.CccdPassport) - @c.HangThanhVien?.TenHang</option>
                    }
                </select>
                <span asp-validation-for="KhachHangId" class="text-danger small"></span>
                <div class="mt-2 small">
                    Chưa có hồ sơ khách? <a href="@Url.Action("Create", "Customer")" class="text-primary text-decoration-none"><i class="fa-solid fa-user-plus"></i> Tạo hồ sơ mới</a>
                </div>
            </div>

            <!-- Ngày Check-in -->
            <div class="col-md-3">
                <label asp-for="NgayCheckIn" class="form-label font-weight-bold small">Ngày Check-in *</label>
                <input asp-for="NgayCheckIn" class="form-control" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" id="checkInDate" required onchange="onDatesChanged()" />
                <span asp-validation-for="NgayCheckIn" class="text-danger small"></span>
            </div>

            <!-- Ngày Check-out -->
            <div class="col-md-3">
                <label asp-for="NgayCheckOut" class="form-label font-weight-bold small">Ngày Check-out *</label>
                <input asp-for="NgayCheckOut" class="form-control" type="date" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" id="checkOutDate" required onchange="onDatesChanged()" />
                <span asp-validation-for="NgayCheckOut" class="text-danger small"></span>
            </div>

            <!-- Số lượng khách -->
            <div class="col-md-2">
                <label asp-for="SoLuongKhach" class="form-label font-weight-bold small">Số khách *</label>
                <input asp-for="SoLuongKhach" class="form-control" type="number" min="1" required />
                <span asp-validation-for="SoLuongKhach" class="text-danger small"></span>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <!-- Tiền đặt cọc -->
            <div class="col-md-4">
                <label asp-for="TienDatCoc" class="form-label font-weight-bold small">Số tiền đặt cọc (VNĐ)</label>
                <input asp-for="TienDatCoc" class="form-control" type="number" min="0" placeholder="0" />
                <span asp-validation-for="TienDatCoc" class="text-danger small"></span>
            </div>

            <!-- Chính sách hủy đặt phòng -->
            <div class="col-md-4">
                <label asp-for="ChinhSachHuyId" class="form-label font-weight-bold small">Điều khoản chính sách hủy *</label>
                <select asp-for="ChinhSachHuyId" class="form-select" required>
                    <option value="">-- Chọn chính sách hủy --</option>
                    @foreach (var cs in ViewBag.ChinhSachHuys)
                    {
                        <option value="@cs.Id">@cs.MoTa</option>
                    }
                </select>
                <span asp-validation-for="ChinhSachHuyId" class="text-danger small"></span>
            </div>

            <!-- Yêu cầu đặc biệt -->
            <div class="col-md-4">
                <label asp-for="YeuCauDacBiet" class="form-label font-weight-bold small">Yêu cầu đặc biệt</label>
                <input asp-for="YeuCauDacBiet" class="form-control" placeholder="Ví dụ: hướng biển, nệm mềm..." />
                <span asp-validation-for="YeuCauDacBiet" class="text-danger small"></span>
            </div>
        </div>

        <hr class="my-4">

        <!-- Chọn loại phòng và số lượng (Group Booking support) -->
        <h6 class="font-weight-bold mb-3"><i class="fa-solid fa-list-check text-primary me-2"></i>Chọn phòng đặt (Có hỗ trợ đặt phòng nhóm)</h6>
        <div id="roomSelectionContainer">
            <div class="row g-3 mb-2 room-selection-row align-items-end">
                <div class="col-md-6">
                    <label class="form-label font-weight-bold small">Loại phòng</label>
                    <select name="roomDetails[0].LoaiPhongId" class="form-select loai-phong-select" onchange="checkAvailability(this)" required>
                        <option value="">-- Chọn loại phòng --</option>
                        @foreach (var lp in ViewBag.LoaiPhongs)
                        {
                            <option value="@lp.Id">@lp.TenLoaiPhong (Niêm yết: @lp.GiaNiemYet.ToString("N0") đ)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label font-weight-bold small">Số lượng phòng đặt</label>
                    <input name="roomDetails[0].SoLuongPhong" type="number" class="form-control so-luong-input" min="1" value="1" onchange="validateQtyLimit(this)" required />
                </div>
                <div class="col-md-3">
                    <div class="text-muted small mb-2">Trạng thái trống: <span class="badge bg-secondary available-qty-badge">Nhập ngày để xem</span></div>
                </div>
            </div>
        </div>

        <button type="button" class="btn btn-outline-primary btn-sm mt-3" onclick="addRoomRow()">
            <i class="fa-solid fa-circle-plus me-1"></i> Thêm loại phòng đặt (Đoàn)
        </button>

        <div class="text-end mt-4">
            <button type="submit" class="btn btn-primary-custom py-2 px-5 font-weight-bold">
                <i class="fa-solid fa-calendar-check me-2"></i> XÁC NHẬN TẠO PHIẾU ĐẶT PHÒNG
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        var rowIndex = 1;
        
        function addRoomRow() {
            var options = $(".loai-phong-select").first().html();
            var rowHtml = `
            <div class="row g-3 mb-2 room-selection-row align-items-end">
                <div class="col-md-6">
                    <select name="roomDetails[${rowIndex}].LoaiPhongId" class="form-select loai-phong-select" onchange="checkAvailability(this)" required>
                        ${options}
                    </select>
                </div>
                <div class="col-md-3">
                    <input name="roomDetails[${rowIndex}].SoLuongPhong" type="number" class="form-control so-luong-input" min="1" value="1" onchange="validateQtyLimit(this)" required />
                </div>
                <div class="col-md-2">
                    <div class="text-muted small mb-2">Trạng thái trống: <span class="badge bg-secondary available-qty-badge">Nhập ngày để xem</span></div>
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-outline-danger btn-sm w-100 py-2" onclick="removeRoomRow(this)">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                </div>
            </div>`;
            $("#roomSelectionContainer").append(rowHtml);
            rowIndex++;
        }
        
        function removeRoomRow(button) {
            $(button).closest(".room-selection-row").remove();
        }
        
        function onDatesChanged() {
            // Khi ngày thay đổi, tải lại thông tin trống phòng cho toàn bộ các dòng
            $(".loai-phong-select").each(function() {
                checkAvailability(this);
            });
        }
        
        function checkAvailability(selectElement) {
            var loaiPhongId = $(selectElement).val();
            var checkIn = $("#checkInDate").val();
            var checkOut = $("#checkOutDate").val();
            var badge = $(selectElement).closest(".room-selection-row").find(".available-qty-badge");
            var input = $(selectElement).closest(".room-selection-row").find(".so-luong-input");
            
            if (!loaiPhongId || !checkIn || !checkOut) {
                badge.removeClass("bg-success bg-danger").addClass("bg-secondary").text("Nhập ngày để xem");
                return;
            }
            
            $.ajax({
                url: '@Url.Action("CheckRoomQty", "Booking")',
                type: 'GET',
                data: {
                    loaiPhongId: loaiPhongId,
                    checkIn: checkIn,
                    checkOut: checkOut
                },
                success: function(response) {
                    badge.removeClass("bg-secondary bg-success bg-danger");
                    if (response.available > 0) {
                        badge.addClass("bg-success").text("Còn trống: " + response.available);
                        input.attr("max", response.available);
                        validateQtyLimit(input[0]);
                    } else {
                        badge.addClass("bg-danger").text("Hết phòng trống");
                        input.removeAttr("max");
                    }
                }
            });
        }
        
        function validateQtyLimit(inputElement) {
            var val = parseInt($(inputElement).val());
            var max = parseInt($(inputElement).attr("max"));
            if (max && val > max) {
                alert("Số lượng phòng đặt vượt quá số lượng phòng trống hiện tại (" + max + " phòng). Vui lòng điều chỉnh lại.");
                $(inputElement).val(max);
            }
        }
    </script>
}
