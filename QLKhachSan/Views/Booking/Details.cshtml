@model QLKhachSan.Models.PhieuDatPhong
@{
    ViewData["Title"] = "Chi tiết đặt phòng " + Model.MaDatPhong;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 font-weight-bold" style="font-family: 'Outfit', sans-serif;">
        <a href="@Url.Action("Index")" class="text-decoration-none text-muted"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a> | Chi tiết phiếu đặt phòng
    </h5>
    <div class="d-flex gap-2">
        @if (Model.TrangThai == "DaXacNhan" || Model.TrangThai == "ChoXacNhan")
        {
            <a href="@Url.Action("CheckInBooking", "CheckInCheckOut", new { bookingId = Model.Id })" class="btn btn-success">
                <i class="fa-solid fa-key me-2"></i> Tiến hành Check-in
            </a>
            <button type="button" class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#modifyDatesModal">
                <i class="fa-solid fa-calendar-days me-2"></i> Đổi lịch ở
            </button>
            <button type="button" class="btn btn-danger" onclick="cancelBooking(@Model.Id, '@Model.MaDatPhong')">
                <i class="fa-solid fa-xmark me-2"></i> Hủy đặt phòng
            </button>
        }
    </div>
</div>

<div class="row g-4">
    <!-- Cột trái: Thông tin đặt phòng -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
            <h5 class="font-weight-bold mb-3" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-file-invoice text-primary me-2"></i>Thông tin phiếu đặt</h5>
            
            <div class="mb-3 border-bottom pb-2">
                <span class="text-muted small">Mã đặt phòng:</span>
                <div class="fs-4 font-weight-bold text-primary">@Model.MaDatPhong</div>
            </div>
            
            <div class="row mb-3">
                <div class="col-md-6 border-end">
                    <span class="text-muted small">Ngày Check-in:</span>
                    <div class="font-weight-bold fs-5 text-dark"><i class="fa-regular fa-calendar me-2 text-primary"></i>@Model.NgayCheckIn.ToString("dd/MM/yyyy")</div>
                </div>
                <div class="col-md-6">
                    <span class="text-muted small">Ngày Check-out:</span>
                    <div class="font-weight-bold fs-5 text-dark"><i class="fa-regular fa-calendar me-2 text-primary"></i>@Model.NgayCheckOut.ToString("dd/MM/yyyy")</div>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6 border-end">
                    <span class="text-muted small">Số khách lưu trú:</span>
                    <div class="font-weight-bold">@Model.SoLuongKhach người</div>
                </div>
                <div class="col-md-6">
                    <span class="text-muted small">Trạng thái phiếu:</span>
                    <div>
                        @{
                            string badgeClass = "";
                            string statusText = "";
                            switch (Model.TrangThai)
                            {
                                case "ChoXacNhan": badgeClass = "bg-warning text-dark"; statusText = "Chờ xác nhận"; break;
                                case "DaXacNhan": badgeClass = "bg-info text-white"; statusText = "Đã xác nhận"; break;
                                case "DaNhanPhong": badgeClass = "bg-success"; statusText = "Đã nhận phòng"; break;
                                case "DaHuy": badgeClass = "bg-danger"; statusText = "Đã hủy"; break;
                                case "NoShow": badgeClass = "bg-secondary"; statusText = "No-show"; break;
                            }
                        }
                        <span class="badge @badgeClass fs-7 px-3 py-1 rounded-pill">@statusText</span>
                    </div>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6 border-end">
                    <span class="text-muted small">Tổng tiền phòng dự kiến:</span>
                    <div class="font-weight-bold text-success fs-5">@Model.TongTienDuKien.ToString("N0") đ</div>
                </div>
                <div class="col-md-6">
                    <span class="text-muted small">Số tiền đã đặt cọc:</span>
                    <div class="font-weight-bold">@Model.TienDatCoc.ToString("N0") đ</div>
                </div>
            </div>

            <div class="mb-2">
                <span class="text-muted small">Yêu cầu đặc biệt:</span>
                <p class="font-weight-bold mb-0">@(string.IsNullOrEmpty(Model.YeuCauDacBiet) ? "Không có" : Model.YeuCauDacBiet)</p>
            </div>
        </div>
    </div>

    <!-- Cột phải: Thông tin khách hàng & Chi tiết phòng đặt -->
    <div class="col-lg-6">
        <!-- Khách hàng -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h5 class="font-weight-bold mb-3" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-user text-primary me-2"></i>Khách hàng đại diện</h5>
            <div class="mb-2">
                <span class="text-muted small">Họ tên:</span>
                <div class="fs-5 font-weight-bold text-dark">@Model.KhachHang?.HoTen</div>
            </div>
            <div class="row mb-2">
                <div class="col-md-6">
                    <span class="text-muted small">Số điện thoại:</span>
                    <div><strong>@Model.KhachHang?.Sdt</strong></div>
                </div>
                <div class="col-md-6">
                    <span class="text-muted small">CCCD / Hộ chiếu:</span>
                    <div><strong>@Model.KhachHang?.CccdPassport</strong></div>
                </div>
            </div>
            <div class="mb-2">
                <span class="text-muted small">Hạng thành viên:</span>
                <div>
                    <span class="badge bg-light text-dark border font-weight-bold">
                        <i class="fa-solid fa-gem text-warning me-1"></i>@Model.KhachHang?.HangThanhVien?.TenHang
                    </span>
                </div>
            </div>
        </div>

        <!-- Chi tiết các phòng đặt -->
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h5 class="font-weight-bold mb-3" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-list text-primary me-2"></i>Danh mục loại phòng đặt</h5>
            <div class="table-responsive border rounded-3">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Loại phòng</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá/đêm</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ct in Model.ChiTietDatPhongs)
                        {
                            <tr>
                                <td class="font-weight-bold text-dark">@ct.LoaiPhong?.TenLoaiPhong</td>
                                <td class="text-center">@ct.SoLuongPhong</td>
                                <td class="text-end">@ct.GiaThoaThuan.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Hủy đặt phòng -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title font-weight-bold">Hủy đặt phòng <span class="text-danger">@Model.MaDatPhong</span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="cancelReason" class="form-label font-weight-bold small">Lý do hủy đặt phòng:</label>
                    <textarea class="form-control" id="cancelReason" rows="3" placeholder="Nhập lý do khách hủy phòng..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-danger" onclick="submitCancel()">Xác nhận hủy đặt phòng</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Đổi lịch ở -->
<div class="modal fade" id="modifyDatesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <form asp-action="ModifyDates" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-header">
                    <h5 class="modal-title font-weight-bold">Thay đổi ngày lưu trú</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="newCheckIn" class="form-label font-weight-bold small">Ngày Check-in mới *</label>
                        <input type="date" name="newCheckIn" id="newCheckIn" class="form-control" value="@Model.NgayCheckIn.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="mb-3">
                        <label for="newCheckOut" class="form-label font-weight-bold small">Ngày Check-out mới *</label>
                        <input type="date" name="newCheckOut" id="newCheckOut" class="form-control" value="@Model.NgayCheckOut.ToString("yyyy-MM-dd")" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" required />
                    </div>
                    <small class="text-muted">Hệ thống sẽ tự động kiểm tra xem khách sạn có đủ phòng trống cho lịch mới này không trước khi cập nhật.</small>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary">Xác nhận thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function submitCancel() {
            var reason = $("#cancelReason").val();
            if (!reason) {
                alert("Vui lòng nhập lý do hủy đặt phòng.");
                return;
            }
            
            $.ajax({
                url: '@Url.Action("Cancel", "Booking")',
                type: 'POST',
                data: {
                    id: @Model.Id,
                    reason: reason
                },
                success: function(response) {
                    if (response.success) {
                        location.href = '@Url.Action("Index")';
                    } else {
                        alert(response.message);
                    }
                },
                error: function() {
                    alert("Có lỗi xảy ra khi thực hiện hủy.");
                }
            });
        }
    </script>
}
