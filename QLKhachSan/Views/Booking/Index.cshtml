@model IEnumerable<QLKhachSan.Models.PhieuDatPhong>
@{
    ViewData["Title"] = "Danh sách Đặt phòng (Booking)";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 font-weight-bold" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-calendar-days text-primary me-2"></i>Phiếu đặt phòng</h5>
    <a href="@Url.Action("Create", "Booking")" class="btn btn-primary-custom">
        <i class="fa-solid fa-calendar-plus me-2"></i>Đặt phòng mới
    </a>
</div>

<div class="table-responsive shadow-sm border rounded-4 bg-white">
    <table class="table table-custom table-hover">
        <thead>
            <tr>
                <th>Mã Đặt Phòng</th>
                <th>Khách hàng đại diện</th>
                <th>Ngày Check-in</th>
                <th>Ngày Check-out</th>
                <th>Tổng số khách</th>
                <th>Dự kiến thu</th>
                <th>Trạng thái</th>
                <th class="text-end">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                string badgeClass = "";
                string statusText = "";
                switch (item.TrangThai)
                {
                    case "ChoXacNhan":
                        badgeClass = "bg-warning text-dark";
                        statusText = "Chờ xác nhận";
                        break;
                    case "DaXacNhan":
                        badgeClass = "bg-info text-white";
                        statusText = "Đã xác nhận";
                        break;
                    case "DaNhanPhong":
                        badgeClass = "bg-success";
                        statusText = "Đã nhận phòng";
                        break;
                    case "DaHuy":
                        badgeClass = "bg-danger";
                        statusText = "Đã hủy";
                        break;
                    case "NoShow":
                        badgeClass = "bg-secondary";
                        statusText = "No-show";
                        break;
                }
                <tr>
                    <td class="font-weight-bold text-primary">@item.MaDatPhong</td>
                    <td>
                        <div><strong>@item.KhachHang?.HoTen</strong></div>
                        <small class="text-muted">@item.KhachHang?.Sdt</small>
                    </td>
                    <td>@item.NgayCheckIn.ToString("dd/MM/yyyy")</td>
                    <td>@item.NgayCheckOut.ToString("dd/MM/yyyy")</td>
                    <td class="text-center">@item.SoLuongKhach người</td>
                    <td class="font-weight-bold text-success">@item.TongTienDuKien.ToString("N0") đ</td>
                    <td>
                        <span class="badge @badgeClass fs-7 px-3 py-2 rounded-pill">@statusText</span>
                    </td>
                    <td class="text-end">
                        <a href="@Url.Action("Details", "Booking", new { id = item.Id })" class="btn btn-sm btn-outline-primary border-0 me-2" title="Xem chi tiết">
                            <i class="fa-solid fa-circle-info"></i> Chi tiết
                        </a>
                        @if (item.TrangThai == "DaXacNhan" || item.TrangThai == "ChoXacNhan")
                        {
                            <a href="@Url.Action("CheckInBooking", "CheckInCheckOut", new { bookingId = item.Id })" class="btn btn-sm btn-success me-2" title="Làm thủ tục nhận phòng">
                                <i class="fa-solid fa-key me-1"></i> Check-in
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="cancelBooking(@item.Id, '@item.MaDatPhong')" title="Hủy đặt phòng">
                                <i class="fa-solid fa-xmark"></i> Hủy
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal Hủy đặt phòng -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title font-weight-bold" id="cancelModalLabel">Hủy đặt phòng <span id="cancelBookingMa" class="text-danger">BK0000</span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="cancelReason" class="form-label font-weight-bold small">Lý do hủy đặt phòng:</label>
                    <textarea class="form-control" id="cancelReason" rows="3" placeholder="Nhập lý do khách hủy phòng..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-danger" onclick="submitCancel()">Xác nhận hủy đặt phòng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var selectedBookingId = 0;
        
        function cancelBooking(id, ma) {
            selectedBookingId = id;
            $("#cancelBookingMa").text(ma);
            $("#cancelReason").val("");
            var myModal = new bootstrap.Modal(document.getElementById('cancelModal'));
            myModal.show();
        }
        
        function submitCancel() {
            var reason = $("#cancelReason").val();
            if (!reason) {
                alert("Vui lòng nhập lý do hủy đặt phòng.");
                return;
            }
            
            $.ajax({
                url: '@Url.Action("Cancel", "Booking")',
                type: 'POST',
                data: {
                    id: selectedBookingId,
                    reason: reason
                },
                success: function(response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        alert(response.message);
                    }
                },
                error: function() {
                    alert("Có lỗi xảy ra khi thực hiện hủy.");
                }
            });
        }
    </script>
}
