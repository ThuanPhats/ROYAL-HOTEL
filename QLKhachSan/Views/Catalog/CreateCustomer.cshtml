@model QLKhachSan.Models.KhachHang
@{
    ViewData["Title"] = "Thêm Khách Hàng Mới";
}

<div class="row">
    <div class="col-lg-7 mx-auto">
        <div class="glass-card">
            <h4 class="text-primary mb-4 border-bottom pb-3">
                <i class="fa-solid fa-user-plus me-2"></i>Thêm Khách Hàng Mới
            </h4>

            <form asp-action="CreateCustomer" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">HỌ VÀ TÊN <span class="text-danger">*</span></label>
                    <input asp-for="HoTen" class="form-control" placeholder="Nhập họ và tên đầy đủ..." required />
                    <span asp-validation-for="HoTen" class="text-danger small"></span>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small">CCCD / PASSPORT <span class="text-danger">*</span></label>
                        <input asp-for="CCCD" class="form-control" placeholder="12 số CCCD hoặc số hộ chiếu..." required />
                        <div class="form-text text-muted">Phải là duy nhất (không trùng)</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small">SỐ ĐIỆN THOẠI <span class="text-danger">*</span></label>
                        <input asp-for="SDT" class="form-control" placeholder="0xxx-xxx-xxx..." required />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold text-muted small">ĐỊA CHỈ</label>
                    <textarea asp-for="DiaChi" class="form-control" rows="2" placeholder="Địa chỉ thường trú (không bắt buộc)..."></textarea>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <a href="@Url.Action("Customers", "Catalog")" class="btn btn-light px-4">Hủy</a>
                    <button type="submit" class="btn btn-premium px-5">
                        <i class="fa-solid fa-floppy-disk me-2"></i>LƯU
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
