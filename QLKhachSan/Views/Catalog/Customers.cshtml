@model IEnumerable<QLKhachSan.Models.KhachHang>
@{
    ViewData["Title"] = "Quản lý Khách Hàng";
}

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h4 class="text-primary m-0"><i class="fa-solid fa-users me-2"></i>Danh sách Khách hàng</h4>
        <div class="d-flex gap-3">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" class="form-control" id="searchInput" placeholder="Tìm kiếm khách hàng...">
            </div>
            <a href="@Url.Action("CreateCustomer", "Catalog")" class="btn btn-premium">
                <i class="fa-solid fa-plus me-1"></i>Thêm Mới
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-premium table-hover align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Họ Tên</th>
                    <th>CCCD/Passport</th>
                    <th>Số Điện Thoại</th>
                    <th>Địa Chỉ</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody id="dataTable">
                @if(Model != null)
                {
                    int i = 1;
                    foreach(var item in Model)
                    {
                        <tr>
                            <td class="text-muted small">@i</td>
                            <td class="fw-bold">@item.HoTen</td>
                            <td><span class="badge bg-light text-dark border">@item.CCCD</span></td>
                            <td>@item.SDT</td>
                            <td class="text-muted">@item.DiaChi</td>
                            <td class="text-end">
                                <a href="@Url.Action("EditCustomer", "Catalog", new { id = item.Id })"
                                   class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form asp-action="DeleteCustomer" method="post" class="d-inline"
                                      onsubmit="return confirm('Xác nhận xóa khách hàng [@item.HoTen]?')">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        i++;
                    }
                }
            </tbody>
        </table>
        @if(Model == null || !Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fa-solid fa-users-slash fs-1 mb-3 text-light d-block"></i>
                <p>Chưa có khách hàng nào. <a href="@Url.Action("CreateCustomer", "Catalog")">Thêm mới ngay!</a></p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function(){
            $("#searchInput").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#dataTable tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
}
