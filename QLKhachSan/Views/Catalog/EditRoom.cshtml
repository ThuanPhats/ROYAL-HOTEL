@model QLKhachSan.Models.Phong
@{
    ViewData["Title"] = "Sửa Phòng";
}

<div class="row">
    <div class="col-lg-6 mx-auto">
        <div class="glass-card">
            <h4 class="text-primary mb-4 border-bottom pb-3">
                <i class="fa-solid fa-pen-to-square me-2"></i>Sửa Thông Tin Phòng
            </h4>
            <form asp-action="EditRoom" method="post">
                <input type="hidden" name="Id" value="@Model.Id" />
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">TÊN PHÒNG <span class="text-danger">*</span></label>
                    <input name="TenPhong" class="form-control form-control-lg" value="@Model.TenPhong" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">LOẠI PHÒNG <span class="text-danger">*</span></label>
                    <select name="LoaiPhongId" class="form-select form-select-lg" required>
                        <option value="">-- Chọn loại phòng --</option>
                        @if (ViewBag.LoaiPhongs != null)
                        {
                            foreach (var lp in ViewBag.LoaiPhongs)
                            {
                                <option value="@lp.Id" selected="@(lp.Id == Model.LoaiPhongId ? "selected" : null)">
                                    @lp.TenLoai — @lp.GiaNgay.ToString("N0")đ/đêm
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="alert alert-info border-0 small">
                    <i class="fa-solid fa-circle-info me-2"></i>
                    Trạng thái hiện tại: <strong>@Model.TrangThai</strong> — không thay đổi khi sửa thông tin phòng.
                </div>
                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a href="@Url.Action("Rooms", "Catalog")" class="btn btn-light px-4">Hủy</a>
                    <button type="submit" class="btn btn-premium px-5">
                        <i class="fa-solid fa-floppy-disk me-2"></i>LƯU THAY ĐỔI
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
