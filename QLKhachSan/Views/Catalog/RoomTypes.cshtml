@model IEnumerable<QLKhachSan.Models.LoaiPhong>
@{
    ViewData["Title"] = "Quản lý Loại Phòng";
}

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h4 class="text-primary m-0"><i class="fa-solid fa-bed me-2"></i>Danh sách Loại phòng</h4>
        <div class="d-flex gap-3">
            <button class="btn btn-premium"><i class="fa-solid fa-plus me-1"></i>Thêm Loại Phòng</button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-premium table-hover align-middle">
            <thead>
                <tr>
                    <th>Tên Loại Phòng</th>
                    <th>Giá Ngày</th>
                    <th>Sức Chứa (Người)</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if(Model != null)
                {
                    foreach(var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.TenLoai</td>
                            <td class="fw-bold text-success">@string.Format("{0:N0}đ", item.GiaNgay)</td>
                            <td><span class="badge bg-primary rounded-pill">@item.SoNguoiToiDa Người</span></td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen-to-square"></i></button>
                                <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
