@model IEnumerable<QLKhachSan.Models.Phong>
@{
    ViewData["Title"] = "Quản lý Phòng";
}

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h4 class="text-primary m-0"><i class="fa-solid fa-door-open me-2"></i>Danh sách Phòng</h4>
        <div class="d-flex gap-3">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" class="form-control" id="searchInput" placeholder="Tìm kiếm phòng...">
            </div>
            <button class="btn btn-premium"><i class="fa-solid fa-plus me-1"></i>Thêm Phòng Mới</button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-premium table-hover align-middle">
            <thead>
                <tr>
                    <th>Tên Phòng</th>
                    <th>Loại Phòng</th>
                    <th>Giá / Đêm</th>
                    <th>Trạng Thái</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody id="dataTable">
                @if(Model != null)
                {
                    foreach(var item in Model)
                    {
                        <tr>
                            <td class="fw-bold fs-5 text-primary">@item.TenPhong</td>
                            <td><span class="badge bg-secondary">@item.LoaiPhong?.TenLoai</span></td>
                            <td class="fw-bold text-success">@string.Format("{0:N0}đ", item.LoaiPhong?.GiaNgay)</td>
                            <td>
                                @if(item.TrangThai == "Trong")
                                {
                                    <span class="badge bg-success"><i class="fa-solid fa-check me-1"></i>Trống</span>
                                }
                                else if(item.TrangThai == "DangSuDung" || item.TrangThai == "DangỞ")
                                {
                                    <span class="badge bg-danger"><i class="fa-solid fa-bed me-1"></i>Đang ở</span>
                                }
                                else if(item.TrangThai == "BaoTri")
                                {
                                    <span class="badge bg-warning text-dark"><i class="fa-solid fa-wrench me-1"></i>Bảo trì</span>
                                }
                                else
                                {
                                    <span class="badge bg-info">@item.TrangThai</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen-to-square"></i></button>
                                <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function(){
            $("#searchInput").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#dataTable tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
}
