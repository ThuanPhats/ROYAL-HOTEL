@model IEnumerable<QLKhachSan.Models.DichVu>
@{
    ViewData["Title"] = "Quản lý Dịch Vụ";
}

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h4 class="text-primary m-0"><i class="fa-solid fa-martini-glass-citrus me-2"></i>Danh sách Dịch vụ</h4>
        <div class="d-flex gap-3">
            <button class="btn btn-premium"><i class="fa-solid fa-plus me-1"></i>Thêm Mới</button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-premium table-hover align-middle">
            <thead>
                <tr>
                    <th>Tên Dịch Vụ</th>
                    <th>Loại Dịch Vụ</th>
                    <th>Giá Bán</th>
                    <th>Trạng Thái</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if(Model != null)
                {
                    foreach(var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-primary">@item.TenDichVu</td>
                            <td><span class="badge bg-light text-dark border">Dịch vụ</span></td>
                            <td class="fw-bold text-success">@string.Format("{0:N0}đ", item.DonGia)</td>
                            <td><span class="badge bg-success"><i class="fa-solid fa-check me-1"></i>Đang bán</span></td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen-to-square"></i></button>
                                <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
