@model QLKhachSan.Models.PhieuDatPhong
@{
    ViewData["Title"] = "Thủ tục nhận phòng - " + Model.MaDatPhong;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 font-weight-bold" style="font-family: 'Outfit', sans-serif;">
        <a href="@Url.Action("Details", "Booking", new { id = Model.Id })" class="text-decoration-none text-muted"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a> | Thủ tục Check-in
    </h5>
</div>

<div class="row g-4">
    <!-- Cột trái: Form gán phòng và chọn khách lưu trú -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h5 class="font-weight-bold mb-4" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-key text-primary me-2"></i>Gán phòng & Đăng ký lưu trú</h5>
            
            <form asp-action="CheckInBooking" method="post">
                <input type="hidden" name="bookingId" value="@Model.Id" />
                
                <!-- Gán phòng cụ thể -->
                <div class="mb-4">
                    <label for="phongId" class="form-label font-weight-bold small">Chọn phòng gán thực tế *</label>
                    <select name="phongId" id="phongId" class="form-select form-select-lg border-primary border-2" required>
                        <option value="">-- Chọn số phòng trống --</option>
                        @foreach (var room in ViewBag.AvailableRooms)
                        {
                            <option value="@room.Id">Phòng @room.MaPhong - Tầng @room.Tang (@room.LoaiPhong?.TenLoaiPhong)</option>
                        }
                    </select>
                    <small class="text-muted">Chỉ hiển thị những phòng trống và sạch phù hợp với loại phòng khách đã đặt.</small>
                </div>

                <!-- Chọn khách lưu trú đi cùng (Đoàn) -->
                <div class="mb-4">
                    <label class="form-label font-weight-bold small mb-2">Đăng ký khách lưu trú đi kèm (nếu có)</label>
                    <div class="border rounded-3 p-3 bg-light" style="max-height: 250px; overflow-y: auto;">
                        @foreach (var customer in ViewBag.Customers)
                        {
                            // Ẩn khách đại diện đã được gán mặc định
                            if (customer.Id == Model.KhachHangId) continue;
                            
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="guestCustomerIds" value="@customer.Id" id="guest-@customer.Id" />
                                <label class="form-check-label small" for="guest-@customer.Id">
                                    <strong>@customer.HoTen</strong> (@customer.CccdPassport) - ĐT: @customer.Sdt
                                </label>
                            </div>
                        }
                    </div>
                    <small class="text-muted">Chọn thêm các khách hàng lưu trú chung phòng để làm thủ tục khai báo tạm trú.</small>
                </div>

                <button type="submit" class="btn btn-success btn-lg w-100 py-3 font-weight-bold shadow-sm">
                    <i class="fa-solid fa-hotel me-2"></i> HOÀN TẤT THỦ TỤC NHẬN PHÒNG (CHECK-IN)
                </button>
            </form>
        </div>
    </div>

    <!-- Cột phải: Thông tin tóm tắt phiếu đặt -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h5 class="font-weight-bold mb-3" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-ticket text-primary me-2"></i>Tóm tắt đặt phòng</h5>
            <div class="mb-3 border-bottom pb-2">
                <span class="text-muted small">Mã phiếu:</span>
                <div class="fs-5 font-weight-bold text-primary">@Model.MaDatPhong</div>
            </div>
            <div class="mb-3 border-bottom pb-2">
                <span class="text-muted small">Khách đại diện đặt:</span>
                <div class="font-weight-bold">@Model.KhachHang?.HoTen</div>
                <small class="text-muted">Số ĐT: @Model.KhachHang?.Sdt | CCCD: @Model.KhachHang?.CccdPassport</small>
            </div>
            <div class="row mb-3">
                <div class="col-6">
                    <span class="text-muted small">Ngày Check-in:</span>
                    <div><strong>@Model.NgayCheckIn.ToString("dd/MM/yyyy")</strong></div>
                </div>
                <div class="col-6">
                    <span class="text-muted small">Ngày Check-out:</span>
                    <div><strong>@Model.NgayCheckOut.ToString("dd/MM/yyyy")</strong></div>
                </div>
            </div>
            <div class="mb-2">
                <span class="text-muted small">Loại phòng đặt:</span>
                @foreach (var ct in Model.ChiTietDatPhongs)
                {
                    <div class="font-weight-bold text-dark"><i class="fa-solid fa-list-check me-2 text-primary"></i>@ct.LoaiPhong?.TenLoaiPhong (x@ct.SoLuongPhong phòng)</div>
                }
            </div>
        </div>
    </div>
</div>
