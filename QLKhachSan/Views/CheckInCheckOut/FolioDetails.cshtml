@model QLKhachSan.Models.PhieuLuuTru
@{
    ViewData["Title"] = "Quản lý Folio - Phòng " + Model.Phong?.MaPhong;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 font-weight-bold" style="font-family: 'Outfit', sans-serif;">
        <a href="@Url.Action("Index")" class="text-decoration-none text-muted"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a> | Chi tiết Folio: @Model.MaFolio
    </h5>
    <div class="d-flex gap-2">
        <a href="@Url.Action("RoomChange", new { id = Model.Id })" class="btn btn-outline-warning">
            <i class="fa-solid fa-arrows-rotate me-2"></i>Đổi phòng
        </a>
        <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#extendModal">
            <i class="fa-solid fa-calendar-plus me-2"></i>Gia hạn lưu trú
        </button>
        <a href="@Url.Action("Order", "Service", new { folioId = Model.Id })" class="btn btn-outline-success">
            <i class="fa-solid fa-concierge-bell me-2"></i>Thêm dịch vụ phòng
        </a>
        <a href="@Url.Action("CalculateCheckOut", new { folioId = Model.Id })" class="btn btn-danger font-weight-bold">
            <i class="fa-solid fa-right-from-bracket me-2"></i>Thanh toán Check-out
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Cột bên trái: Chi tiết chi phí Folio -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h5 class="font-weight-bold mb-4" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-file-invoice text-primary me-2"></i>Bảng tổng hợp chi phí (Folio Sheet)</h5>
            
            <div class="table-responsive border rounded-3 mb-3">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ngày ghi nhận</th>
                            <th>Mục chi phí</th>
                            <th>Nội dung</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.ChiTietFolios.OrderBy(c => c.NgayGhiNhan))
                        {
                            string badgeClass = "";
                            switch (item.LoaiChiTiet)
                            {
                                case "TienPhong": badgeClass = "bg-primary"; break;
                                case "PhuThu": badgeClass = "bg-danger"; break;
                                case "DichVu": badgeClass = "bg-success"; break;
                                case "GiamTru": badgeClass = "bg-secondary"; break;
                            }
                            <tr>
                                <td class="small text-muted">@item.NgayGhiNhan.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge @badgeClass rounded-pill">@item.LoaiChiTiet</span>
                                </td>
                                <td>@item.NoiDung</td>
                                <td class="text-center">@item.SoLuong</td>
                                <td class="text-end">@item.DonGia.ToString("N0") đ</td>
                                <td class="text-end font-weight-bold">@item.ThanhTien.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Tóm tắt số dư công nợ -->
            <div class="row justify-content-end text-end g-2 mt-2">
                <div class="col-md-5">
                    <div class="d-flex justify-content-between py-1 border-bottom">
                        <span class="text-muted">Tổng cộng phát sinh:</span>
                        <strong>@Model.ChiTietFolios.Sum(c => c.ThanhTien).ToString("N0") đ</strong>
                    </div>
                    <div class="d-flex justify-content-between py-1 border-bottom">
                        <span class="text-muted">Giảm trừ (đã đặt cọc/voucher):</span>
                        <strong class="text-danger">- @Model.GiamTru.ToString("N0") đ</strong>
                    </div>
                    <div class="d-flex justify-content-between py-2 text-primary fs-5 font-weight-bold">
                        <span>Cần thanh toán:</span>
                        <span>@((Model.ChiTietFolios.Sum(c => c.ThanhTien) - Model.GiamTru).ToString("N0")) đ</span>
                    </div>
                </div>
            </div>

            <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                <a href="@Url.Action("SplitBill", "Billing", new { folioId = Model.Id })" class="btn btn-outline-secondary btn-sm">
                    <i class="fa-solid fa-scissors me-1"></i> Tách hoá đơn (Split Bill)
                </a>
                <a href="@Url.Action("CreateVAT", "Billing", new { folioId = Model.Id })" class="btn btn-outline-primary btn-sm">
                    <i class="fa-solid fa-file-invoice-dollar me-1"></i> Xuất hoá đơn VAT điện tử
                </a>
            </div>
        </div>
    </div>

    <!-- Cột bên phải: Thông tin lưu trú & khách hàng -->
    <div class="col-lg-4">
        <!-- Thông tin lưu trú -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h5 class="font-weight-bold mb-3" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-circle-info text-primary me-2"></i>Thông tin lưu trú</h5>
            <div class="mb-3">
                <span class="text-muted small">Phòng:</span>
                <div class="fs-4 font-weight-bold text-dark"><i class="fa-solid fa-door-closed text-danger me-2"></i>@Model.Phong?.MaPhong</div>
                <small class="text-muted">@Model.Phong?.LoaiPhong?.TenLoaiPhong</small>
            </div>
            <div class="mb-2">
                <span class="text-muted small">Khách đại diện:</span>
                <div><strong>@Model.KhachHang?.HoTen</strong></div>
                <small class="text-muted">Hạng: @Model.KhachHang?.HangThanhVien?.TenHang | Điểm tích lũy: @Model.KhachHang?.LoyaltyPoints</small>
            </div>
            <div class="mb-2">
                <span class="text-muted small">Thời điểm check-in:</span>
                <div><strong>@Model.NgayCheckInAct.ToString("dd/MM/yyyy HH:mm")</strong></div>
            </div>
        </div>

        <!-- Khách đi cùng -->
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h5 class="font-weight-bold mb-3" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-users text-primary me-2"></i>Danh sách lưu trú (Đoàn)</h5>
            <ul class="list-group list-group-flush mb-0">
                @foreach (var guest in Model.DangKyLuuTrus)
                {
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@guest.KhachHang?.HoTen</strong>
                            <div class="small text-muted">@guest.KhachHang?.CccdPassport</div>
                        </div>
                        <span class="badge bg-light text-dark border">Khách ở cùng</span>
                    </li>
                }
                @if (!Model.DangKyLuuTrus.Any())
                {
                    <li class="list-group-item px-0 py-2 text-muted small">Không khai báo khách đi kèm.</li>
                }
            </ul>
        </div>
    </div>
</div>

<!-- Modal gia hạn ở -->
<div class="modal fade" id="extendModal" tabindex="-1" aria-labelledby="extendModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <form asp-action="ExtendStay" method="post">
                <input type="hidden" name="folioId" value="@Model.Id" />
                <div class="modal-header">
                    <h5 class="modal-title font-weight-bold" id="extendModalLabel">Gia hạn thời gian lưu trú</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="additionalNights" class="form-label font-weight-bold small">Số đêm muốn kéo dài thêm:</label>
                        <input type="number" name="additionalNights" id="additionalNights" class="form-control" min="1" value="1" required />
                        <small class="text-muted">Hệ thống sẽ tự động kiểm tra xem phòng có vướng lịch đặt phòng nào sau đó không trước khi kéo dài.</small>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary">Xác nhận gia hạn</button>
                </div>
            </form>
        </div>
    </div>
</div>
