@model QLKhachSan.Models.PhieuLuuTru
@{
    ViewData["Title"] = "Thủ tục đổi phòng - Folio " + Model.MaFolio;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 font-weight-bold" style="font-family: 'Outfit', sans-serif;">
        <a href="@Url.Action("FolioDetails", new { id = Model.Id })" class="text-decoration-none text-muted"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a> | Thủ tục đổi phòng
    </h5>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4 max-width-md mx-auto" style="max-width: 600px;">
    <h5 class="font-weight-bold mb-4" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-arrows-rotate text-warning me-2"></i>Đổi phòng lưu trú</h5>
    
    <div class="mb-4 bg-light p-3 rounded-3 border">
        <div class="row g-2 small">
            <div class="col-6"><strong>Mã Folio:</strong> @Model.MaFolio</div>
            <div class="col-6"><strong>Phòng hiện tại:</strong> Phòng @Model.Phong?.MaPhong</div>
            <div class="col-12"><strong>Khách đại diện:</strong> @Model.KhachHang?.HoTen</div>
            <div class="col-12"><strong>Thời điểm check-in:</strong> @Model.NgayCheckInAct.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
    </div>

    <form asp-action="RoomChange" method="post">
        <input type="hidden" name="folioId" value="@Model.Id" />

        <!-- Phòng mới -->
        <div class="mb-3">
            <label for="newPhongId" class="form-label font-weight-bold small">Chọn phòng mới để chuyển đến *</label>
            <select name="newPhongId" id="newPhongId" class="form-select" required>
                <option value="">-- Chọn phòng trống sạch --</option>
                @foreach (var room in ViewBag.AvailableRooms)
                {
                    <option value="@room.Id">Phòng @room.MaPhong - Tầng @room.Tang (@room.LoaiPhong?.TenLoaiPhong) (Đơn giá: @room.LoaiPhong?.GiaNiemYet.ToString("N0") đ)</option>
                }
            </select>
            <small class="text-muted">Chỉ hiển thị các phòng hiện tại đang trống và đã dọn dẹp sạch sẽ.</small>
        </div>

        <!-- Lý do đổi phòng -->
        <div class="mb-4">
            <label for="reason" class="form-label font-weight-bold small">Lý do đổi phòng *</label>
            <textarea name="reason" id="reason" class="form-control" rows="3" placeholder="Ví dụ: Khách nâng hạng phòng, máy lạnh phòng cũ hỏng..." required></textarea>
        </div>

        <button type="submit" class="btn btn-warning w-100 py-2 font-weight-bold">
            <i class="fa-solid fa-check me-2"></i> XÁC NHẬN ĐỔI PHÒNG
        </button>
    </form>
</div>
