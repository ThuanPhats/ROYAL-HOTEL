@{
    ViewData["Title"] = "Check-in Walk-In (Khách vãng lai)";
    var loaiPhongs = ViewBag.LoaiPhongs as IEnumerable<QLKhachSan.Models.LoaiPhong>;
    var phongs = ViewBag.Phongs as IEnumerable<QLKhachSan.Models.Phong>;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h3 class="fw-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
            <i class="fa-solid fa-person-walking-luggage text-success me-2"></i>Check-in Walk-In
        </h3>
        <p class="text-muted mb-0 small">Tiếp nhận khách vãng lai không có đặt phòng trước.</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-3">
        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
    </a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4" role="alert">
        <i class="fa-solid fa-circle-xmark me-2"></i>
        <strong>Có lỗi xảy ra:</strong>
        <ul class="mb-0 mt-1 small">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Thanh tiến trình -->
<div class="card border-0 shadow-sm rounded-4 mb-4 px-4 py-3">
    <div class="d-flex align-items-center gap-3">
        <div class="d-flex align-items-center gap-2" id="step1Indicator">
            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold"
                 style="width:36px;height:36px;">1</div>
            <span class="fw-bold small text-primary">Thông tin khách</span>
        </div>
        <div class="flex-grow-1 border-top border-2 border-primary-subtle"></div>
        <div class="d-flex align-items-center gap-2" id="step2Indicator">
            <div class="rounded-circle bg-light text-muted border d-flex align-items-center justify-content-center fw-bold"
                 id="step2Circle" style="width:36px;height:36px;">2</div>
            <span class="fw-bold small text-muted" id="step2Label">Chọn phòng & Xác nhận</span>
        </div>
    </div>
</div>

<form asp-action="WalkIn" asp-controller="CheckInCheckOut" method="post" id="walkinForm">
    @Html.AntiForgeryToken()

    <!-- ===== BƯỚC 1: THÔNG TIN KHÁCH ===== -->
    <div id="step1" class="step-panel">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h6 class="fw-bold text-uppercase text-muted small mb-3">
                <i class="fa-solid fa-user-circle me-2 text-primary"></i>
                Bước 1 — Thông tin khách hàng
            </h6>

            <div class="row">
                <div class="col-md-8 mb-3">
                    <label class="form-label fw-bold small">Họ và tên *</label>
                    <input type="text" name="customer.HoTen" class="form-control"
                           placeholder="Nhập họ và tên đầy đủ" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold small">Giới tính</label>
                    <select name="customer.GioiTinh" class="form-select">
                        <option value="">-- Chọn --</option>
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                        <option value="Khác">Khác</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold small">Số CCCD / Passport *</label>
                    <div class="input-group">
                        <input type="text" name="customer.CccdPassport" id="cccdInput"
                               class="form-control" placeholder="Số CCCD 12 chữ số hoặc Passport" required />
                        <button type="button" class="btn btn-outline-secondary" id="lookupBtn"
                                title="Tra cứu khách hàng theo CCCD">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                    </div>
                    <div class="form-text">Nhấn 🔍 để kiểm tra khách hàng đã có trên hệ thống.</div>
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label fw-bold small">Số điện thoại</label>
                    <input type="tel" name="customer.Sdt" class="form-control" placeholder="0912 345 678" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label fw-bold small">Quốc tịch</label>
                    <input type="text" name="customer.QuocTich" class="form-control" value="Việt Nam" />
                </div>
            </div>

            <!-- Thông báo tra cứu -->
            <div id="lookupResult" class="d-none">
                <div class="alert alert-info border-0 rounded-3 small">
                    <i class="fa-solid fa-circle-info me-2"></i>
                    <span id="lookupMessage"></span>
                </div>
            </div>

            <div class="text-end mt-2">
                <button type="button" class="btn btn-primary px-5" id="nextStepBtn">
                    Tiếp theo — Chọn phòng
                    <i class="fa-solid fa-arrow-right ms-2"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- ===== BƯỚC 2: CHỌN PHÒNG & XÁC NHẬN ===== -->
    <div id="step2" class="step-panel d-none">
        <div class="row g-4">
            <!-- Chọn loại phòng và phòng -->
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h6 class="fw-bold text-uppercase text-muted small mb-3">
                        <i class="fa-solid fa-bed me-2 text-success"></i>
                        Bước 2 — Chọn phòng & Điều kiện lưu trú
                    </h6>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">Loại phòng *</label>
                        <select name="loaiPhongId" class="form-select" id="loaiPhongSelect">
                            <option value="">-- Chọn loại phòng --</option>
                            @if (loaiPhongs != null)
                            {
                                @foreach (var lp in loaiPhongs)
                                {
                                    <option value="@lp.Id"
                                            data-gia="@lp.GiaNiemYet"
                                            data-suc="@lp.SucChua">
                                        @lp.TenLoaiPhong — @lp.GiaNiemYet.ToString("N0") đ/đêm (Sức chứa: @lp.SucChua người)
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">Chọn phòng trống *</label>
                        <select name="phongId" class="form-select" id="phongSelect">
                            <option value="">-- Chọn loại phòng trước --</option>
                            @if (phongs != null)
                            {
                                @foreach (var p in phongs.Where(p => p.TrangThai == "Trong-Sach"))
                                {
                                    <option value="@p.Id"
                                            data-loai="@p.LoaiPhongId"
                                            class="phong-option">
                                        Phòng @p.MaPhong — Tầng @p.Tang
                                    </option>
                                }
                            }
                        </select>
                        <div class="form-text">Chỉ hiển thị phòng trạng thái <strong>Trống – Sạch</strong>.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Số đêm lưu trú *</label>
                            <input type="number" name="stayNights" id="stayNights"
                                   class="form-control" min="1" max="365" value="1" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Số khách</label>
                            <input type="number" name="guestCount" id="guestCount"
                                   class="form-control" min="1" value="1" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Panel tổng kết & xác nhận -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm rounded-4 mb-3">
                    <div class="card-header bg-success text-white rounded-top-4 py-3 px-4">
                        <h6 class="fw-bold mb-0">
                            <i class="fa-solid fa-receipt me-2"></i>Xác nhận đặt phòng
                        </h6>
                    </div>
                    <div class="card-body px-4">
                        <table class="table table-borderless small mb-0">
                            <tr>
                                <td class="text-muted fw-bold">Khách hàng:</td>
                                <td id="summaryName" class="fw-bold text-dark">—</td>
                            </tr>
                            <tr>
                                <td class="text-muted fw-bold">Phòng:</td>
                                <td id="summaryRoom" class="fw-bold">—</td>
                            </tr>
                            <tr>
                                <td class="text-muted fw-bold">Giá/đêm:</td>
                                <td id="summaryPrice" class="fw-bold text-success">—</td>
                            </tr>
                            <tr>
                                <td class="text-muted fw-bold">Số đêm:</td>
                                <td id="summaryNights" class="fw-bold">1</td>
                            </tr>
                            <tr class="border-top">
                                <td class="text-muted fw-bold">Tổng dự kiến:</td>
                                <td id="summaryTotal" class="fw-bold text-primary fs-6">—</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success btn-lg py-3 fw-bold">
                        <i class="fa-solid fa-door-open me-2"></i>
                        XÁC NHẬN CHECK-IN
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="backStepBtn">
                        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại Bước 1
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        // Chuyển bước
        document.getElementById('nextStepBtn').addEventListener('click', function () {
            const name = document.querySelector('[name="customer.HoTen"]').value.trim();
            const cccd = document.querySelector('[name="customer.CccdPassport"]').value.trim();
            if (!name || !cccd) {
                alert('Vui lòng nhập đầy đủ Họ tên và CCCD/Passport.');
                return;
            }
            document.getElementById('step1').classList.add('d-none');
            document.getElementById('step2').classList.remove('d-none');

            // Cập nhật thanh tiến trình
            document.getElementById('step2Circle').classList.remove('bg-light', 'text-muted', 'border');
            document.getElementById('step2Circle').classList.add('bg-primary', 'text-white');
            document.getElementById('step2Label').classList.remove('text-muted');
            document.getElementById('step2Label').classList.add('text-primary');

            // Cập nhật tóm tắt
            document.getElementById('summaryName').textContent = name;
        });

        document.getElementById('backStepBtn').addEventListener('click', function () {
            document.getElementById('step2').classList.add('d-none');
            document.getElementById('step1').classList.remove('d-none');
        });

        // Lọc phòng theo loại phòng
        document.getElementById('loaiPhongSelect').addEventListener('change', function () {
            const loaiId = this.value;
            const phongSelect = document.getElementById('phongSelect');
            const options = phongSelect.querySelectorAll('.phong-option');
            phongSelect.value = '';

            options.forEach(opt => {
                opt.style.display = (!loaiId || opt.dataset.loai === loaiId) ? '' : 'none';
            });

            // Cập nhật tóm tắt giá
            const selected = this.options[this.selectedIndex];
            const gia = parseFloat(selected.dataset.gia || 0);
            document.getElementById('summaryPrice').textContent = gia > 0
                ? gia.toLocaleString('vi-VN') + ' đ/đêm' : '—';
            updateTotal(gia);
        });

        document.getElementById('phongSelect').addEventListener('change', function () {
            const text = this.options[this.selectedIndex]?.text || '—';
            document.getElementById('summaryRoom').textContent = this.value ? text : '—';
        });

        document.getElementById('stayNights').addEventListener('input', function () {
            document.getElementById('summaryNights').textContent = this.value;
            const loaiSel = document.getElementById('loaiPhongSelect');
            const gia = parseFloat(loaiSel.options[loaiSel.selectedIndex]?.dataset.gia || 0);
            updateTotal(gia);
        });

        function updateTotal(pricePerNight) {
            const nights = parseInt(document.getElementById('stayNights').value) || 1;
            const total = pricePerNight * nights;
            document.getElementById('summaryTotal').textContent = total > 0
                ? total.toLocaleString('vi-VN') + ' đ' : '—';
        }

        // Tra cứu khách (giả lập) — trong thực tế sẽ gọi API
        document.getElementById('lookupBtn').addEventListener('click', function () {
            const cccd = document.getElementById('cccdInput').value.trim();
            if (!cccd) { alert('Vui lòng nhập số CCCD/Passport.'); return; }
            // Tìm trong danh sách khách hiện tại (nếu có ViewBag.Customers)
            document.getElementById('lookupResult').classList.remove('d-none');
            document.getElementById('lookupMessage').textContent =
                'Đã nhập CCCD: ' + cccd + '. Hệ thống sẽ tự động kiểm tra và tạo hồ sơ khách nếu chưa có.';
        });
    </script>
}
