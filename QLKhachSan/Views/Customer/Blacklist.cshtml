@model IEnumerable<QLKhachSan.Models.DanhSachDen>
@{
    ViewData["Title"] = "Danh sách đen (Blacklist)";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h3 class="fw-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
            <i class="fa-solid fa-user-slash text-danger me-2"></i>Danh sách đen (Blacklist)
        </h3>
        <p class="text-muted mb-0 small">Danh sách khách hàng bị cấm hoặc cần cảnh báo khi tiếp nhận.</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-3">
        <i class="fa-solid fa-arrow-left me-2"></i>Về danh sách khách hàng
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
    <div class="table-responsive border rounded-3">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-danger">
                <tr>
                    <th>#</th>
                    <th>Khách hàng</th>
                    <th>CCCD / Passport</th>
                    <th>Lý do</th>
                    <th>Ngày áp dụng</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center" width="130">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{int stt = 1;}
                @foreach (var item in Model)
                {
                    <tr class="@(item.IsActive ? "" : "opacity-50")">
                        <td class="text-muted small">@stt++</td>
                        <td>
                            <div class="fw-bold text-dark">@item.KhachHang?.HoTen</div>
                            <small class="text-muted">
                                <i class="fa-solid fa-phone me-1"></i>@(item.KhachHang?.Sdt ?? "N/A")
                            </small>
                        </td>
                        <td>
                            <span class="font-monospace text-secondary small">@item.KhachHang?.CccdPassport</span>
                        </td>
                        <td>
                            <span class="text-danger small">@item.LyDo</span>
                        </td>
                        <td class="small text-muted">
                            @item.NgayApDung.ToString("dd/MM/yyyy")
                        </td>
                        <td class="text-center">
                            @if (item.IsActive)
                            {
                                <span class="badge bg-danger rounded-pill px-3 py-2">
                                    <i class="fa-solid fa-ban me-1"></i>Đang chặn
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill px-3 py-2">
                                    <i class="fa-solid fa-check me-1"></i>Đã gỡ
                                </span>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.IsActive)
                            {
                                <form asp-action="RemoveFromBlacklist" method="post" style="display:inline;"
                                      onsubmit="return confirm('Xác nhận gỡ khách hàng này khỏi danh sách đen?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-success btn-sm rounded-2" title="Gỡ khỏi Blacklist">
                                        <i class="fa-solid fa-user-check me-1"></i>Gỡ chặn
                                    </button>
                                </form>
                            }
                            <a href="@Url.Action("Details", "Customer", new { id = item.KhachHangId })"
                               class="btn btn-outline-primary btn-sm rounded-2 ms-1" title="Xem hồ sơ">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <i class="fa-solid fa-shield-check fs-2 text-success mb-3 d-block"></i>
                            Không có khách hàng nào trong danh sách đen.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="mt-3 small text-muted">
        <i class="fa-solid fa-circle-info me-1"></i>
        Tổng số: <strong>@Model.Count()</strong> bản ghi |
        Đang chặn: <strong class="text-danger">@Model.Count(b => b.IsActive)</strong>
    </div>
</div>
