@model IEnumerable<QLKhachSan.Models.KhachHang>
@{
    ViewData["Title"] = "Quản lý khách hàng";
    bool showDeleted = ViewBag.ShowDeleted ?? false;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h3 class="font-weight-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
                <i class="fa-solid fa-users text-primary me-2"></i>Hồ sơ khách hàng
            </h3>
            <p class="text-muted mb-0 small">Quản lý danh sách khách hàng lưu trú, hạng thành viên VIP và lịch sử lưu trú.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Blacklist")" class="btn btn-outline-danger rounded-3">
                <i class="fa-solid fa-user-slash me-2"></i>Danh sách đen (Blacklist)
            </a>
            @if (showDeleted)
            {
                <a href="@Url.Action("Index", new { showDeleted = false })" class="btn btn-outline-secondary rounded-3">
                    <i class="fa-solid fa-eye me-2"></i>Ẩn khách hàng đã xóa mềm
                </a>
            }
            else
            {
                <a href="@Url.Action("Index", new { showDeleted = true })" class="btn btn-outline-secondary rounded-3">
                    <i class="fa-solid fa-eye-slash me-2"></i>Hiển thị đã xóa mềm
                </a>
            }
            <a href="@Url.Action("Create")" class="btn btn-primary rounded-3">
                <i class="fa-solid fa-user-plus me-2"></i>Thêm khách hàng mới
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <!-- Bộ lọc nhanh -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa-solid fa-magnifying-glass"></i></span>
                    <input type="text" id="customerSearch" class="form-control border-start-0 rounded-end-3" placeholder="Tìm kiếm theo tên, số điện thoại, CCCD/Passport..." />
                </div>
            </div>
        </div>

        <div class="table-responsive border rounded-3">
            <table class="table table-hover align-middle mb-0" id="customersTable">
                <thead class="table-light">
                    <tr>
                        <th>Khách hàng</th>
                        <th>Thông tin liên hệ</th>
                        <th>Giấy tờ tùy thân</th>
                        <th class="text-center">Hạng thành viên</th>
                        <th class="text-center">Điểm tích lũy</th>
                        <th class="text-center">Trạng thái</th>
                        <th width="180" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        bool isBlacklisted = item.Blacklists != null && item.Blacklists.Any(b => b.IsActive);
                        string rowClass = item.IsDeleted ? "opacity-60 bg-light-subtle" : "";
                        
                        <tr class="customer-row @rowClass" data-search="@(item.HoTen.ToLower() + " " + item.Sdt + " " + item.CccdPassport.ToLower())">
                            <td>
                                <div>
                                    <strong class="text-dark">@item.HoTen</strong>
                                    @if (isBlacklisted)
                                    {
                                        <span class="badge bg-danger ms-2"><i class="fa-solid fa-user-slash me-1"></i>Blacklist</span>
                                    }
                                </div>
                                <small class="text-muted">Quốc tịch: @(item.QuocTich ?? "Việt Nam") | Giới tính: @(item.GioiTinh ?? "N/A")</small>
                            </td>
                            <td>
                                <div><i class="fa-solid fa-phone text-muted small me-1"></i> @(item.Sdt ?? "N/A")</div>
                                <div class="small text-muted"><i class="fa-solid fa-envelope text-muted small me-1"></i> @(item.Email ?? "N/A")</div>
                            </td>
                            <td>
                                <span class="font-monospace text-secondary">@item.CccdPassport</span>
                            </td>
                            <td class="text-center">
                                @{
                                    string badgeColor = "bg-secondary";
                                    switch (item.HangThanhVien?.TenHang?.ToLower())
                                    {
                                        case "gold": badgeColor = "bg-warning text-dark"; break;
                                        case "platinum": badgeColor = "bg-info text-white"; break;
                                        case "diamond": badgeColor = "bg-primary text-white"; break;
                                    }
                                }
                                <span class="badge @badgeColor rounded-pill px-3 py-2">
                                    <i class="fa-solid fa-award me-1"></i>@(item.HangThanhVien?.TenHang ?? "Tiêu chuẩn")
                                </span>
                            </td>
                            <td class="text-center font-weight-bold text-dark">
                                @item.LoyaltyPoints.ToString("N0")
                            </td>
                            <td class="text-center">
                                @if (item.IsDeleted)
                                {
                                    <span class="badge bg-danger rounded-pill px-2 py-1">Đã xóa mềm</span>
                                }
                                else
                                {
                                    <span class="badge bg-success rounded-pill px-2 py-1">Hoạt động</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-outline-primary btn-sm rounded-2" title="Chi tiết">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-outline-warning btn-sm rounded-2" title="Chỉnh sửa">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    
                                    @if (item.IsDeleted)
                                    {
                                        <form asp-action="Restore" method="post" style="display:inline;" onsubmit="return confirm('Khôi phục hồ sơ khách hàng này?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-outline-success btn-sm rounded-2" title="Khôi phục">
                                                <i class="fa-solid fa-trash-arrow-up"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="SoftDelete" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn tạm ẩn hồ sơ khách hàng này?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-2" title="Xóa mềm">
                                                <i class="fa-solid fa-user-minus"></i>
                                            </button>
                                        </form>
                                    }

                                    @if (!isBlacklisted)
                                    {
                                        <button class="btn btn-outline-dark btn-sm rounded-2 btn-add-blacklist" data-id="@item.Id" data-name="@item.HoTen" title="Đưa vào Blacklist">
                                            <i class="fa-solid fa-user-slash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <i class="fa-solid fa-users-slash fs-2 text-secondary mb-3 d-block"></i>
                                Không tìm thấy khách hàng nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Thêm Blacklist -->
<div class="modal fade" id="blacklistModal" tabindex="-1" aria-labelledby="blacklistModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <form asp-action="AddToBlacklist" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="customerId" id="blacklistCustomerId" />
                <div class="modal-header">
                    <h5 class="modal-title font-weight-bold" id="blacklistModalLabel">Đưa khách hàng vào Blacklist</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted">Hành động này sẽ chuyển trạng thái của khách hàng <strong id="blacklistCustomerName" class="text-danger"></strong> thành bị chặn. Vui lòng ghi rõ lý do.</p>
                    <div class="mb-3">
                        <label for="reason" class="form-label font-weight-bold small text-muted">Lý do đưa vào danh sách đen:</label>
                        <textarea name="reason" id="reason" class="form-control rounded-3" rows="3" placeholder="Nhập lý do chi tiết..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">Xác nhận chặn</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .opacity-60 {
        opacity: 0.6;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Customer Live Search
            $('#customerSearch').on('keyup', function () {
                let searchVal = $(this).val().toLowerCase();
                $('.customer-row').each(function () {
                    let searchData = $(this).data('search');
                    if (searchData.indexOf(searchVal) > -1) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            });

            // Blacklist button click to open modal
            $('.btn-add-blacklist').on('click', function () {
                let id = $(this).data('id');
                let name = $(this).data('name');

                $('#blacklistCustomerId').val(id);
                $('#blacklistCustomerName').text(name);
                
                let myModal = new bootstrap.Modal(document.getElementById('blacklistModal'));
                myModal.show();
            });
        });
    </script>
}
