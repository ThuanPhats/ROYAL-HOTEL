@model QLKhachSan.Models.NhanVien
@{
    ViewData["Title"] = "Thêm mới nhân viên";
    var departments = ViewBag.BoPhans as IEnumerable<QLKhachSan.Models.BoPhan> ?? new List<QLKhachSan.Models.BoPhan>();
    var positions = ViewBag.ChucVus as IEnumerable<QLKhachSan.Models.ChucVu> ?? new List<QLKhachSan.Models.ChucVu>();
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-person-plus me-2"></i>Thêm mới nhân viên</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" asp-antiforgery="true" id="createEmployeeForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <h5 class="mb-3 border-bottom pb-2 text-secondary">Thông tin cá nhân</h5>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="MaNV" class="form-label font-weight-bold">Mã nhân viên (Tự động tạo)</label>
                                <input asp-for="MaNV" class="form-control bg-light" id="maNVInput" readonly required />
                                <span asp-validation-for="MaNV" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="HoTen" class="form-label font-weight-bold">Họ và tên</label>
                                <input asp-for="HoTen" class="form-control" placeholder="Nhập họ và tên..." required />
                                <span asp-validation-for="HoTen" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="NgaySinh" class="form-label font-weight-bold">Ngày sinh</label>
                                <input asp-for="NgaySinh" class="form-control" type="date" required />
                                <span asp-validation-for="NgaySinh" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Cccd" class="form-label font-weight-bold">Số CCCD</label>
                                <input asp-for="Cccd" class="form-control" placeholder="Nhập số CCCD..." required />
                                <span asp-validation-for="Cccd" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Sdt" class="form-label font-weight-bold">Số điện thoại</label>
                                <input asp-for="Sdt" class="form-control" placeholder="Số điện thoại..." required />
                                <span asp-validation-for="Sdt" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label font-weight-bold">Email</label>
                                <input asp-for="Email" class="form-control" type="email" placeholder="Email..." required />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>

                        <h5 class="mt-4 mb-3 border-bottom pb-2 text-secondary">Thông tin công việc</h5>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="BoPhanId" class="form-label font-weight-bold">Bộ phận</label>
                                <select asp-for="BoPhanId" class="form-select" id="boPhanSelect" required>
                                    <option value="">-- Chọn bộ phận --</option>
                                    @foreach (var dept in departments)
                                    {
                                        <option value="@dept.Id">@dept.TenBoPhan</option>
                                    }
                                </select>
                                <span asp-validation-for="BoPhanId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ChucVuId" class="form-label font-weight-bold">Chức vụ</label>
                                <select asp-for="ChucVuId" class="form-select" id="chucVuSelect" required>
                                    <option value="">-- Chọn chức vụ --</option>
                                    @foreach (var pos in positions)
                                    {
                                        <option value="@pos.Id" data-bophan="@pos.BoPhanId">@pos.TenChucVu</option>
                                    }
                                </select>
                                <span asp-validation-for="ChucVuId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NgayVaoLam" class="form-label font-weight-bold">Ngày vào làm</label>
                            <input asp-for="NgayVaoLam" class="form-control" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                            <span asp-validation-for="NgayVaoLam" class="text-danger"></span>
                        </div>

                        <h5 class="mt-4 mb-3 border-bottom pb-2 text-secondary"><i class="bi bi-shield-lock me-2"></i>Tạo tài khoản hệ thống</h5>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label for="accountUsername" class="form-label font-weight-bold">Tên đăng nhập</label>
                                <input type="text" id="accountUsername" name="Username" class="form-control" placeholder="Tên đăng nhập..." />
                            </div>
                            <div class="col-md-4">
                                <label for="accountPassword" class="form-label font-weight-bold">Mật khẩu</label>
                                <input type="password" id="accountPassword" name="Password" class="form-control" placeholder="Mật khẩu..." />
                            </div>
                            <div class="col-md-4">
                                <label for="accountRole" class="form-label font-weight-bold">Vai trò (Role)</label>
                                <select id="accountRole" name="Role" class="form-select">
                                    <option value="LeTan">Lễ tân (Receptionist)</option>
                                    <option value="HouseKeeping">Buồng phòng (Housekeeper)</option>
                                    <option value="KyThuat">Kỹ thuật (Technician)</option>
                                    <option value="QuanLy">Quản lý (Manager)</option>
                                    <option value="Admin">Quản trị viên (Admin)</option>
                                </select>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Tạo nhân viên
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Generate code on load
    document.addEventListener("DOMContentLoaded", function() {
        const randomNum = Math.floor(1000 + Math.random() * 9000);
        document.getElementById("maNVInput").value = "NV" + randomNum;
    });

    // Cascade position selection based on department
    document.getElementById('boPhanSelect').addEventListener('change', function() {
        const selectedDeptId = this.value;
        const chucVuSelect = document.getElementById('chucVuSelect');
        const options = chucVuSelect.querySelectorAll('option');
        
        options.forEach(opt => {
            if (opt.value === "") {
                opt.style.display = 'block';
            } else {
                const deptId = opt.getAttribute('data-bophan');
                if (selectedDeptId === "" || deptId === selectedDeptId) {
                    opt.style.display = 'block';
                } else {
                    opt.style.display = 'none';
                }
            }
        });
        chucVuSelect.value = "";
    });
</script>
