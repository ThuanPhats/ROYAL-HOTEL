@model QLKhachSan.Models.NhanVien
@{
    ViewData["Title"] = "Chi tiết nhân viên";
    var schedules = ViewBag.Schedules as IEnumerable<QLKhachSan.Models.LichLamViec> ?? new List<QLKhachSan.Models.LichLamViec>();
    
    // Filter schedules for the next 7 days (including today)
    var today = DateTime.Today;
    var next7Days = today.AddDays(7);
    var upcomingSchedules = schedules
        .Where(s => s.NgayLamViec.Date >= today && s.NgayLamViec.Date <= next7Days)
        .OrderBy(s => s.NgayLamViec)
        .ToList();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Hồ sơ nhân viên</h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil-square me-1"></i>Sửa thông tin
            </a>
            <a asp-action="AssignShift" asp-route-employeeId="@Model.Id" class="btn btn-primary">
                <i class="bi bi-calendar-plus me-1"></i>Phân ca
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Quay lại
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Thông tin chi tiết</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <div class="d-inline-flex justify-content-center align-items-center bg-light text-primary rounded-circle border border-primary" style="width: 100px; height: 100px; font-size: 2.5rem;">
                            <i class="bi bi-person"></i>
                        </div>
                        <h4 class="mt-3">@Model.HoTen</h4>
                        <span class="badge bg-secondary">@Model.MaNV</span>
                    </div>
                    
                    <table class="table table-borderless">
                        <tr>
                            <th style="width: 35%">Bộ phận:</th>
                            <td>@(Model.BoPhan?.TenBoPhan ?? "Chưa xác định")</td>
                        </tr>
                        <tr>
                            <th>Chức vụ:</th>
                            <td>@(Model.ChucVu?.TenChucVu ?? "Chưa xác định")</td>
                        </tr>
                        <tr>
                            <th>Số CCCD:</th>
                            <td>@Model.Cccd</td>
                        </tr>
                        <tr>
                            <th>Số điện thoại:</th>
                            <td>@(Model.Sdt ?? "Chưa cập nhật")</td>
                        </tr>
                        <tr>
                            <th>Email:</th>
                            <td>@(Model.Email ?? "Chưa cập nhật")</td>
                        </tr>
                        <tr>
                            <th>Ngày sinh:</th>
                            <td>@(Model.NgaySinh?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</td>
                        </tr>
                        <tr>
                            <th>Ngày vào làm:</th>
                            <td>@Model.NgayVaoLam.ToString("dd/MM/yyyy")</td>
                        </tr>
                        <tr>
                            <th>Trạng thái hoạt động:</th>
                            <td>
                                @if (Model.IsDeleted)
                                {
                                    <span class="badge bg-danger">Đã tạm nghỉ/Ngưng hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-calendar-week me-2"></i>Lịch làm việc (7 ngày tới)</h5>
                    <a asp-action="ScheduleIndex" class="btn btn-sm btn-outline-light">Xem lịch chung</a>
                </div>
                <div class="card-body">
                    @if (upcomingSchedules.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>Ngày</th>
                                        <th>Thứ</th>
                                        <th>Ca làm việc</th>
                                        <th>Thời gian ca</th>
                                        <th>Chấm công</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sched in upcomingSchedules)
                                    {
                                        var dayOfWeek = sched.NgayLamViec.ToString("dddd", new System.Globalization.CultureInfo("vi-VN"));
                                        <tr>
                                            <td><strong>@sched.NgayLamViec.ToString("dd/MM/yyyy")</strong></td>
                                            <td><span class="text-muted text-capitalize">@dayOfWeek</span></td>
                                            <td>
                                                @switch (sched.CaLamViec?.TenCa)
                                                {
                                                    case "Ca sáng":
                                                    case "Sáng":
                                                        <span class="badge bg-warning text-dark">Sáng</span>
                                                        break;
                                                    case "Ca chiều":
                                                    case "Chiều":
                                                        <span class="badge bg-primary">Chiều</span>
                                                        break;
                                                    case "Ca đêm":
                                                    case "Đêm":
                                                        <span class="badge bg-dark">Đêm</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@(sched.CaLamViec?.TenCa ?? "Chưa phân")</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @if (sched.CaLamViec != null)
                                                {
                                                    <span>@sched.CaLamViec.GioBatDau.ToString(@"hh\:mm") - @sched.CaLamViec.GioKetThuc.ToString(@"hh\:mm")</span>
                                                }
                                                else
                                                {
                                                    <span>-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (sched.CheckInTime != null)
                                                {
                                                    <div><small class="text-success">Vào: @sched.CheckInTime.Value.ToString("HH:mm")</small></div>
                                                }
                                                @if (sched.CheckOutTime != null)
                                                {
                                                    <div><small class="text-info">Ra: @sched.CheckOutTime.Value.ToString("HH:mm")</small></div>
                                                }
                                                @if (sched.CheckInTime == null && sched.CheckOutTime == null)
                                                {
                                                    if (sched.NgayLamViec.Date < DateTime.Today)
                                                    {
                                                        <span class="text-danger"><small>Vắng mặt</small></span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted"><small>Chưa bắt đầu</small></span>
                                                    }
                                                }
                                                else
                                                {
                                                    @switch (sched.TrangThaiChambCong)
                                                    {
                                                        case "DungGio":
                                                            <span class="badge bg-success bg-opacity-75 text-white d-block mt-1">Đúng giờ</span>
                                                            break;
                                                        case "Tre":
                                                            <span class="badge bg-danger bg-opacity-75 text-white d-block mt-1">Đi trễ</span>
                                                            break;
                                                        case "Som":
                                                            <span class="badge bg-warning text-dark d-block mt-1">Về sớm</span>
                                                            break;
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center my-4">
                            Chưa phân ca làm việc nào cho nhân viên này trong 7 ngày tới.
                            <div class="mt-2">
                                <a asp-action="AssignShift" asp-route-employeeId="@Model.Id" class="btn btn-sm btn-primary">Phân ca ngay</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
