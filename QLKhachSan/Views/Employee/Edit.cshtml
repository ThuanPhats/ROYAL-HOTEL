@model QLKhachSan.Models.NhanVien
@{
    ViewData["Title"] = "Chỉnh sửa thông tin nhân viên";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 fw-bold" style="font-family: 'Outfit', sans-serif;">
        <a href="@Url.Action("Index")" class="text-decoration-none text-muted">
            <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
        </a> | Chỉnh sửa nhân viên <span class="text-primary">@Model.MaNV</span>
    </h5>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4 mx-auto" style="max-width: 720px;">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="AppUserId" />

        <h6 class="fw-bold text-muted text-uppercase mb-3 small">
            <i class="fa-solid fa-id-badge me-2"></i>Thông tin nhân viên
        </h6>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="MaNV" class="form-label fw-bold small"></label>
                <input asp-for="MaNV" class="form-control" placeholder="NV001" />
                <span asp-validation-for="MaNV" class="text-danger small"></span>
            </div>
            <div class="col-md-8 mb-3">
                <label asp-for="HoTen" class="form-label fw-bold small"></label>
                <input asp-for="HoTen" class="form-control" placeholder="Họ và tên đầy đủ" />
                <span asp-validation-for="HoTen" class="text-danger small"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="NgaySinh" class="form-label fw-bold small"></label>
                <input asp-for="NgaySinh" class="form-control" type="date" />
                <span asp-validation-for="NgaySinh" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Cccd" class="form-label fw-bold small"></label>
                <input asp-for="Cccd" class="form-control" placeholder="Số CCCD 12 chữ số" />
                <span asp-validation-for="Cccd" class="text-danger small"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Sdt" class="form-label fw-bold small"></label>
                <input asp-for="Sdt" class="form-control" placeholder="0912 345 678" />
                <span asp-validation-for="Sdt" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Email" class="form-label fw-bold small">Email</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="email@khachsan.vn" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="NgayVaoLam" class="form-label fw-bold small"></label>
            <input asp-for="NgayVaoLam" class="form-control" type="date" />
            <span asp-validation-for="NgayVaoLam" class="text-danger small"></span>
        </div>

        <hr class="my-3" />
        <h6 class="fw-bold text-muted text-uppercase mb-3 small">
            <i class="fa-solid fa-sitemap me-2"></i>Phân công & Phân quyền
        </h6>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="BoPhanId" class="form-label fw-bold small">Bộ phận *</label>
                <select asp-for="BoPhanId" class="form-select" id="boPhanSelect">
                    <option value="">-- Chọn bộ phận --</option>
                    @foreach (var bp in ViewBag.BoPhans)
                    {
                        <option value="@bp.Id">@bp.TenBoPhan</option>
                    }
                </select>
                <span asp-validation-for="BoPhanId" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="ChucVuId" class="form-label fw-bold small">Chức vụ *</label>
                <select asp-for="ChucVuId" class="form-select">
                    <option value="">-- Chọn chức vụ --</option>
                    @foreach (var cv in ViewBag.ChucVus)
                    {
                        <option value="@cv.Id" data-bophan="@cv.BoPhanId">@cv.TenChucVu</option>
                    }
                </select>
                <span asp-validation-for="ChucVuId" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-primary w-100 py-2">
                <i class="fa-solid fa-floppy-disk me-2"></i> LƯU THAY ĐỔI
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary w-50 py-2">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        // Lọc chức vụ theo bộ phận khi thay đổi
        document.getElementById('boPhanSelect').addEventListener('change', function () {
            const boPhanId = this.value;
            const chucVuSelect = document.querySelector('select[name="ChucVuId"]');
            const options = chucVuSelect.querySelectorAll('option');
            options.forEach(opt => {
                if (!opt.value) return; // giữ option placeholder
                opt.style.display = (!boPhanId || opt.dataset.bophan === boPhanId) ? '' : 'none';
            });
        });
        // Khởi tạo lần đầu
        document.getElementById('boPhanSelect').dispatchEvent(new Event('change'));
    </script>
}
