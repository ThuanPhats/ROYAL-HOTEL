@inject QLKhachSan.Services.IEmployeeService EmployeeService
@model IEnumerable<QLKhachSan.Models.LichLamViec>
@{
    ViewData["Title"] = "Lịch làm việc tổng hợp";
    
    // Get target date and calculate week boundaries (Monday to Sunday)
    var targetDate = (DateTime)(ViewBag.TargetDate ?? DateTime.Today);
    int diff = (7 + (targetDate.DayOfWeek - DayOfWeek.Monday)) % 7;
    var monday = targetDate.AddDays(-1 * diff).Date;
    
    var weekDates = Enumerable.Range(0, 7).Select(i => monday.AddDays(i)).ToList();
    
    // Fetch all employees and departments
    var allEmployees = await EmployeeService.GetAllEmployeesAsync();
    var departments = await EmployeeService.GetBoPhansAsync();
    
    // Filter by department if requested
    string deptQuery = Context.Request.Query["boPhanId"];
    int selectedDeptId = 0;
    if (int.TryParse(deptQuery, out selectedDeptId) && selectedDeptId > 0)
    {
        allEmployees = allEmployees.Where(e => e.BoPhanId == selectedDeptId).ToList();
    }
    
    // Fetch all schedules for this week
    var weekSchedules = new List<QLKhachSan.Models.LichLamViec>();
    foreach (var date in weekDates)
    {
        var dayScheds = await EmployeeService.GetSchedulesByDateAsync(date);
        weekSchedules.AddRange(dayScheds);
    }
    
    // Helper to get day name in Vietnamese
    Func<int, string> getDayName = (dayIndex) => 
    {
        if (dayIndex == 6) return "Chủ Nhật";
        return $"Thứ {dayIndex + 2}";
    };
}

<div class="container-fluid mt-4 px-4">
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h3 class="mb-1 text-primary"><i class="bi bi-calendar3 me-2"></i>Lịch phân ca tổng hợp</h3>
                    <p class="text-muted mb-0">Tuần từ ngày <strong>@monday.ToString("dd/MM/yyyy")</strong> đến ngày <strong>@weekDates[6].ToString("dd/MM/yyyy")</strong></p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <a asp-action="ScheduleIndex" asp-route-date="@monday.AddDays(-7).ToString("yyyy-MM-dd")" asp-route-boPhanId="@selectedDeptId" class="btn btn-outline-secondary">
                        <i class="bi bi-chevron-left me-1"></i>Tuần trước
                    </a>
                    <a asp-action="ScheduleIndex" asp-route-date="@DateTime.Today.ToString("yyyy-MM-dd")" asp-route-boPhanId="@selectedDeptId" class="btn btn-outline-primary">
                        Hôm nay
                    </a>
                    <a asp-action="ScheduleIndex" asp-route-date="@monday.AddDays(7).ToString("yyyy-MM-dd")" asp-route-boPhanId="@selectedDeptId" class="btn btn-outline-secondary">
                        Tuần sau<i class="bi bi-chevron-right ms-1"></i>
                    </a>
                    <a asp-action="AssignShift" class="btn btn-primary ms-2">
                        <i class="bi bi-plus-circle me-1"></i>Phân ca mới
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters Section -->
    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form method="get" asp-action="ScheduleIndex" class="row align-items-center g-3">
                <input type="hidden" name="date" value="@targetDate.ToString("yyyy-MM-dd")" />
                <div class="col-md-4">
                    <label for="boPhanId" class="form-label font-weight-bold mb-1">Lọc theo Bộ phận</label>
                    <select id="boPhanId" name="boPhanId" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Tất cả bộ phận --</option>
                        @foreach (var dept in departments)
                        {
                            <!option value="@dept.Id" @(selectedDeptId == dept.Id ? "selected" : "")>@dept.TenBoPhan</!option>
                        }
                    </select>
                </div>
                <div class="col-md-2 mt-md-4">
                    <a asp-action="ScheduleIndex" asp-route-date="@targetDate.ToString("yyyy-MM-dd")" class="btn btn-secondary w-100">Xóa lọc</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Schedule Grid -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover align-middle mb-0" style="min-width: 900px;">
                    <thead class="table-dark text-center">
                        <tr>
                            <th style="width: 200px;">Nhân viên</th>
                            @for (int i = 0; i < 7; i++)
                            {
                                var date = weekDates[i];
                                var isToday = date.Date == DateTime.Today;
                                <th class="@(isToday ? "bg-primary border-primary text-white" : "")">
                                    <div>@getDayName(i)</div>
                                    <small class="fw-normal">@date.ToString("dd/MM")</small>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (allEmployees.Any())
                        {
                            foreach (var emp in allEmployees)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="fw-bold">@emp.HoTen</div>
                                        <div class="text-muted" style="font-size: 0.8rem;">@emp.MaNV - @(emp.ChucVu?.TenChucVu)</div>
                                    </td>
                                    @for (int i = 0; i < 7; i++)
                                    {
                                        var date = weekDates[i];
                                        var sched = weekSchedules.FirstOrDefault(s => s.NhanVienId == emp.Id && s.NgayLamViec.Date == date.Date);
                                        <td class="text-center p-2" style="height: 70px;">
                                            @if (sched?.CaLamViec != null)
                                            {
                                                var shiftName = sched.CaLamViec.TenCa;
                                                var timeStr = $"{sched.CaLamViec.GioBatDau.ToString(@"hh\:mm")}-{sched.CaLamViec.GioKetThuc.ToString(@"hh\:mm")}";
                                                
                                                @switch (shiftName)
                                                {
                                                    case "Ca sáng":
                                                    case "Sáng":
                                                        <span class="badge bg-warning text-dark d-block p-2" title="@timeStr">
                                                            <i class="bi bi-sun-fill me-1"></i>Sáng
                                                        </span>
                                                        break;
                                                    case "Ca chiều":
                                                    case "Chiều":
                                                        <span class="badge bg-primary d-block p-2" title="@timeStr">
                                                            <i class="bi bi-cloud-sun-fill me-1"></i>Chiều
                                                        </span>
                                                        break;
                                                    case "Ca đêm":
                                                    case "Đêm":
                                                        <span class="badge bg-dark d-block p-2" title="@timeStr">
                                                            <i class="bi bi-moon-stars-fill me-1"></i>Đêm
                                                        </span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary d-block p-2" title="@timeStr">
                                                            @shiftName
                                                        </span>
                                                        break;
                                                }
                                                
                                                @if (sched.CheckInTime != null)
                                                {
                                                    <div style="font-size: 0.75rem;" class="text-success mt-1">
                                                        <i class="bi bi-clock-history me-1"></i>Đã vào ca
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted font-monospace" style="font-size: 0.8rem;">Off</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center p-5 text-muted">
                                    <i class="bi bi-people-fill display-4 d-block mb-3"></i>
                                    Không tìm thấy nhân viên nào phù hợp với bộ lọc.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
