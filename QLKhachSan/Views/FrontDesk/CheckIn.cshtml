@model IEnumerable<QLKhachSan.Models.PhieuDatPhong>
@{
    ViewData["Title"] = "Nhận Phòng (Check-in)";
}

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h4 class="text-primary m-0"><i class="fa-solid fa-bell-concierge me-2"></i>Danh sách Khách đến Nhận phòng</h4>
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" class="form-control" id="searchInput" placeholder="Tìm tên khách, SĐT...">
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-premium table-hover align-middle">
            <thead>
                <tr>
                    <th>Mã Booking</th>
                    <th>Khách Hàng</th>
                    <th>SĐT</th>
                    <th>Phòng Đặt</th>
                    <th>Ngày Nhận</th>
                    <th>Ngày Trả</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody id="bookingTable">
                @if(Model != null && Model.Any())
                {
                    foreach(var item in Model)
                    {
                        <tr>
                            <td class="font-weight-bold text-primary">#BK-@item.Id.ToString("D4")</td>
                            <td class="fw-bold">@item.KhachHang?.HoTen</td>
                            <td>@item.KhachHang?.SDT</td>
                            <td>
                                @if(item.ChiTietDatPhongs != null)
                                {
                                    foreach(var ct in item.ChiTietDatPhongs)
                                    {
                                        <span class="badge bg-info text-dark me-1 border border-secondary">@ct.Phong?.TenPhong</span>
                                    }
                                }
                            </td>
                            <td>@item.NgayLap.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if(item.ChiTietDatPhongs?.FirstOrDefault() != null)
                                {
                                    @item.ChiTietDatPhongs.First().NgayTra.ToString("dd/MM/yyyy")
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="ProcessCheckIn" method="post" onsubmit="return confirm('Xác nhận khách đã đến nhận phòng và giao chìa khóa?');">
                                    <input type="hidden" name="bookingId" value="@item.Id" />
                                    <button type="submit" class="btn btn-premium btn-sm rounded-pill px-3">
                                        <i class="fa-solid fa-key me-1"></i> Check-in
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-calendar-xmark fs-1 mb-3 text-light"></i>
                            <p>Hôm nay không có khách nào đặt trước chờ Check-in.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function(){
            $("#searchInput").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#bookingTable tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
}
