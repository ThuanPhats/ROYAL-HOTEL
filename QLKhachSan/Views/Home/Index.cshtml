@{
    ViewData["Title"] = "Sơ đồ phòng & Dashboard";
}

<!-- Dashboard Cards -->
<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="glass-card stat-card border-bottom border-4 border-primary">
            <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                <i class="fa-solid fa-percent"></i>
            </div>
            <div class="stat-details">
                <div class="stat-title">Công suất phòng</div>
                <div class="stat-value">@ViewBag.OccupancyRate.ToString("F1")%</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="glass-card stat-card border-bottom border-4 border-warning">
            <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                <i class="fa-solid fa-sack-dollar"></i>
            </div>
            <div class="stat-details">
                <div class="stat-title">Doanh thu hôm nay</div>
                <div class="stat-value">@ViewBag.TodayRevenue.ToString("N0")đ</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="glass-card stat-card border-bottom border-4 border-danger">
            <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                <i class="fa-solid fa-bed"></i>
            </div>
            <div class="stat-details">
                <div class="stat-title">Phòng đang sử dụng</div>
                <div class="stat-value">@ViewBag.OccupiedRooms / @ViewBag.TotalRooms</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="glass-card stat-card border-bottom border-4 border-success">
            <div class="stat-icon bg-success bg-opacity-10 text-success">
                <i class="fa-solid fa-calendar-check"></i>
            </div>
            <div class="stat-details">
                <div class="stat-title">Check-in dự kiến</div>
                <div class="stat-value">0</div>
            </div>
        </div>
    </div>
</div>

<!-- Sơ đồ phòng và chú thích -->
<div class="glass-card mb-4 p-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h5 class="m-0 text-primary" style="font-family: 'Outfit', sans-serif;">
            <i class="fa-solid fa-map-location-dot me-2"></i>Sơ đồ trạng thái phòng thời gian thực
        </h5>
        <!-- Chú thích trạng thái -->
        <div class="d-flex gap-3 flex-wrap small font-weight-bold">
            <div><span class="badge bg-success me-1">&nbsp;</span> Trống</div>
            <div><span class="badge bg-danger me-1">&nbsp;</span> Đang sử dụng</div>
            <div><span class="badge bg-info me-1">&nbsp;</span> Đã đặt</div>
            <div><span class="badge bg-warning me-1">&nbsp;</span> Bảo trì</div>
        </div>
    </div>

    <!-- Sơ đồ Grid phân theo tầng -->
    @if (ViewBag.RoomsByFloor != null)
    {
        @foreach (var floor in ViewBag.RoomsByFloor)
        {
            <div class="mb-5">
                <h6 class="text-muted border-bottom pb-2 font-weight-bold mb-3">
                    <i class="fa-solid fa-layer-group me-2 text-primary"></i>TẦNG @floor.Key
                </h6>
                <div class="room-grid">
                    @foreach (var room in floor.Value)
                    {
                        string stateClass = "";
                        string stateIcon = "";
                        switch (room.TrangThai)
                        {
                            case "Trong":
                                stateClass = "status-trong";
                                stateIcon = "fa-door-open";
                                break;
                            case "DangSuDung":
                            case "DangỞ":
                                stateClass = "status-dang-o";
                                stateIcon = "fa-bed";
                                break;
                            case "DaDat":
                                stateClass = "status-da-dat";
                                stateIcon = "fa-suitcase";
                                break;
                            case "BaoTri":
                                stateClass = "status-bao-tri";
                                stateIcon = "fa-wrench";
                                break;
                        }
                        
                        <div class="room-box @stateClass">
                            <div class="room-status-bar"></div>
                            <div class="text-end mb-1">
                                <i class="fa-solid @stateIcon room-icon fs-5"></i>
                            </div>
                            <div class="room-number text-primary">@room.TenPhong</div>
                            <div class="room-type">@room.LoaiPhong?.TenLoai</div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        // Animations or SignalR logic could go here
    </script>
}
