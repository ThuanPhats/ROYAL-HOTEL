@model QLKhachSan.Models.KhuyenMai
@{
    ViewData["Title"] = "Sửa Khuyến Mãi";
}

<div class="row">
    <div class="col-lg-6 mx-auto">
        <div class="glass-card">
            <h4 class="text-warning mb-4 border-bottom pb-3">
                <i class="fa-solid fa-pen-to-square me-2"></i>Sửa Khuyến Mãi
            </h4>
            <form asp-action="EditPromotion" method="post">
                <input type="hidden" name="Id" value="@Model.Id" />
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">TÊN CHƯƠNG TRÌNH *</label>
                    <input name="TenKM" class="form-control" value="@Model.TenKM" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">% GIẢM GIÁ *</label>
                    <div class="input-group">
                        <input type="number" name="PhanTramGiam" class="form-control" value="@Model.PhanTramGiam" min="1" max="100" step="1" required />
                        <span class="input-group-text">%</span>
                    </div>
                </div>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small">NGÀY BẮT ĐẦU *</label>
                        <input type="date" name="NgayBatDau" class="form-control" value="@Model.NgayBatDau.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small">NGÀY KẾT THÚC *</label>
                        <input type="date" name="NgayKetThuc" class="form-control" value="@Model.NgayKetThuc.ToString("yyyy-MM-dd")" required />
                    </div>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <a href="@Url.Action("Promotions")" class="btn btn-light px-4">Hủy</a>
                    <button type="submit" class="btn btn-warning px-5">
                        <i class="fa-solid fa-floppy-disk me-2"></i>LƯU THAY ĐỔI
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
