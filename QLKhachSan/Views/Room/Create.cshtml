@model QLKhachSan.Models.Phong
@{
    ViewData["Title"] = "Thêm phòng mới";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 font-weight-bold" style="font-family: 'Outfit', sans-serif;">
        <a href="@Url.Action("Index")" class="text-decoration-none text-muted">
            <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
        </a> | Thêm phòng mới
    </h5>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4 mx-auto" style="max-width: 600px;">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

        <div class="mb-3">
            <label asp-for="MaPhong" class="form-label fw-bold small"></label>
            <input asp-for="MaPhong" class="form-control" placeholder="Ví dụ: P101, P202..." />
            <span asp-validation-for="MaPhong" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Tang" class="form-label fw-bold small"></label>
            <input asp-for="Tang" class="form-control" type="number" min="1" placeholder="Tầng 1, 2, 3..." />
            <span asp-validation-for="Tang" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="LoaiPhongId" class="form-label fw-bold small">Loại phòng *</label>
            <select asp-for="LoaiPhongId" class="form-select">
                <option value="">-- Chọn loại phòng --</option>
                @foreach (var lp in ViewBag.LoaiPhongs)
                {
                    <option value="@lp.Id">@lp.TenLoaiPhong — Giá: @lp.GiaNiemYet.ToString("N0") đ/đêm</option>
                }
            </select>
            <span asp-validation-for="LoaiPhongId" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="TrangThai" class="form-label fw-bold small">Trạng thái phòng *</label>
            <select asp-for="TrangThai" class="form-select">
                <option value="Trong-Sach">Trống – Sạch (Vacant Clean)</option>
                <option value="Trong-ChuaDon">Trống – Chưa dọn (Vacant Dirty)</option>
                <option value="DangSuDung">Đang có khách (Occupied)</option>
                <option value="DaDat">Đã đặt trước (Reserved)</option>
                <option value="BaoTri">Đang bảo trì (Out of Order)</option>
            </select>
            <span asp-validation-for="TrangThai" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100 py-2">
                <i class="fa-solid fa-plus me-2"></i> THÊM PHÒNG
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary w-50 py-2">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
