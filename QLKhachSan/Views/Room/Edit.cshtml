@model QLKhachSan.Models.Phong
@{
    ViewData["Title"] = "Chỉnh sửa Phòng " + Model.MaPhong;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 font-weight-bold" style="font-family: 'Outfit', sans-serif;">
        <a href="@Url.Action("Index")" class="text-decoration-none text-muted"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a> | Chỉnh sửa Phòng
    </h5>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4 max-width-md mx-auto" style="max-width: 600px;">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />

        <div class="mb-3">
            <label asp-for="MaPhong" class="form-label font-weight-bold small"></label>
            <input asp-for="MaPhong" class="form-control" placeholder="Ví dụ: P101" required />
            <span asp-validation-for="MaPhong" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Tang" class="form-label font-weight-bold small"></label>
            <input asp-for="Tang" class="form-control" type="number" min="1" required />
            <span asp-validation-for="Tang" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="LoaiPhongId" class="form-label font-weight-bold small">Loại phòng *</label>
            <select asp-for="LoaiPhongId" class="form-select" required>
                <option value="">-- Chọn loại phòng --</option>
                @foreach (var lp in ViewBag.LoaiPhongs)
                {
                    <option value="@lp.Id">@lp.TenLoaiPhong (Giá niêm yết: @lp.GiaNiemYet.ToString("N0") đ)</option>
                }
            </select>
            <span asp-validation-for="LoaiPhongId" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="TrangThai" class="form-label font-weight-bold small">Trạng thái phòng *</label>
            <select asp-for="TrangThai" class="form-select" required>
                <option value="Trong-Sach">Trống - Sạch</option>
                <option value="Trong-ChuaDon">Trống - Chưa dọn (Bẩn)</option>
                <option value="DangSuDung">Đang ở (Có khách)</option>
                <option value="DaDat">Đã đặt trước</option>
                <option value="BaoTri">Đang bảo trì</option>
            </select>
            <span asp-validation-for="TrangThai" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary-custom w-100 py-2">
            <i class="fa-solid fa-floppy-disk me-2"></i> LƯU THAY ĐỔI
        </button>
    </form>
</div>
