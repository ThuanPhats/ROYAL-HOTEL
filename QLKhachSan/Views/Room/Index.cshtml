@model IEnumerable<QLKhachSan.Models.Phong>
@{
    ViewData["Title"] = "Danh sách Phòng";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h5 class="m-0 font-weight-bold" style="font-family: 'Outfit', sans-serif;"><i class="fa-solid fa-door-open text-primary me-2"></i>Quản lý Phòng</h5>
    @if (User.IsInRole("Admin") || User.IsInRole("QuanLy"))
    {
        <a href="@Url.Action("Create", "Room")" class="btn btn-primary-custom">
            <i class="fa-solid fa-circle-plus me-2"></i>Thêm Phòng mới
        </a>
    }
</div>

<div class="table-responsive shadow-sm border rounded-4 bg-white">
    <table class="table table-custom table-hover">
        <thead>
            <tr>
                <th>Mã Phòng</th>
                <th>Tầng</th>
                <th>Loại Phòng</th>
                <th>Diện tích (m2)</th>
                <th>Giá niêm yết</th>
                <th>Trạng thái</th>
                @if (User.IsInRole("Admin") || User.IsInRole("QuanLy"))
                {
                    <th class="text-end">Thao tác</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                string badgeClass = "";
                string statusText = "";
                switch (item.TrangThai)
                {
                    case "Trong-Sach":
                        badgeClass = "bg-success";
                        statusText = "Trống-Sạch";
                        break;
                    case "Trong-ChuaDon":
                        badgeClass = "bg-warning text-dark";
                        statusText = "Trống-Bẩn";
                        break;
                    case "DangSuDung":
                        badgeClass = "bg-danger";
                        statusText = "Đang ở";
                        break;
                    case "DaDat":
                        badgeClass = "bg-primary";
                        statusText = "Đã đặt";
                        break;
                    case "BaoTri":
                        badgeClass = "bg-secondary";
                        statusText = "Bảo trì";
                        break;
                }
                <tr>
                    <td class="font-weight-bold fs-5 text-dark">@item.MaPhong</td>
                    <td>Tầng @item.Tang</td>
                    <td>@item.LoaiPhong?.TenLoaiPhong</td>
                    <td>@item.LoaiPhong?.DienTich m²</td>
                    <td class="font-weight-bold">@item.LoaiPhong?.GiaNiemYet.ToString("N0") đ</td>
                    <td>
                        <span class="badge @badgeClass fs-7 px-3 py-2 rounded-pill">@statusText</span>
                    </td>
                    @if (User.IsInRole("Admin") || User.IsInRole("QuanLy"))
                    {
                        <td class="text-end">
                            <a href="@Url.Action("Edit", "Room", new { id = item.Id })" class="btn btn-sm btn-outline-primary border-0 me-2" title="Sửa">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa phòng này không?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger border-0" title="Xóa">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </form>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
