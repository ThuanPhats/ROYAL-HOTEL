@model QLKhachSan.Models.LoaiPhong
@{
    ViewData["Title"] = "Thêm loại phòng";
    var amenities = ViewBag.TienNghis as IEnumerable<QLKhachSan.Models.TienNghi> ?? new List<QLKhachSan.Models.TienNghi>();
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-door-open-fill me-2"></i>Thêm loại phòng mới</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="LoaiPhongCreate" method="post" asp-antiforgery="true">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="TenLoaiPhong" class="form-label font-weight-bold"></label>
                            <input asp-for="TenLoaiPhong" class="form-control" placeholder="Ví dụ: Deluxe Double, Suite VIP..." required />
                            <span asp-validation-for="TenLoaiPhong" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="DienTich" class="form-label font-weight-bold"></label>
                                <div class="input-group">
                                    <input asp-for="DienTich" class="form-control" type="number" min="1" step="0.1" required />
                                    <span class="input-group-text">m²</span>
                                </div>
                                <span asp-validation-for="DienTich" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="GiaNiemYet" class="form-label font-weight-bold"></label>
                                <div class="input-group">
                                    <input asp-for="GiaNiemYet" class="form-control" type="number" min="0" required />
                                    <span class="input-group-text">đ</span>
                                </div>
                                <span asp-validation-for="GiaNiemYet" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="SoGiuong" class="form-label font-weight-bold"></label>
                                <input asp-for="SoGiuong" class="form-control" type="number" min="1" max="10" required />
                                <span asp-validation-for="SoGiuong" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="SucChua" class="form-label font-weight-bold"></label>
                                <div class="input-group">
                                    <input asp-for="SucChua" class="form-control" type="number" min="1" max="20" required />
                                    <span class="input-group-text">người</span>
                                </div>
                                <span asp-validation-for="SucChua" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="HuongNhin" class="form-label font-weight-bold"></label>
                            <input asp-for="HuongNhin" class="form-control" placeholder="Ví dụ: Hướng hồ bơi, Hướng thành phố, Hướng biển..." />
                            <span asp-validation-for="HuongNhin" class="text-danger"></span>
                        </div>

                        <h5 class="mt-4 mb-3 border-bottom pb-2 text-secondary"><i class="bi bi-box-fill me-2"></i>Chọn tiện nghi phòng</h5>
                        @if (amenities.Any())
                        {
                            <div class="row mb-4">
                                @foreach (var tn in amenities)
                                {
                                    <div class="col-md-4 col-sm-6 mb-2">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="selectedTienNghiIds" value="@tn.Id" id="tn_@tn.Id">
                                            <label class="form-check-label" for="tn_@tn.Id">
                                                @tn.TenTienNghi
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning mb-4">
                                Chưa có tiện nghi nào trong hệ thống. Vui lòng thêm tiện nghi ở phần quản lý tiện nghi trước.
                            </div>
                        }

                        <div class="d-flex justify-content-between">
                            <a asp-action="LoaiPhongIndex" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Tạo loại phòng
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
