@model IEnumerable<QLKhachSan.Models.LoaiPhong>
@{
    ViewData["Title"] = "Quản lý loại phòng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary mb-1"><i class="bi bi-door-open me-2"></i>Danh mục loại phòng</h2>
            <p class="text-muted mb-0">Quản lý danh sách, diện tích, sức chứa và chính sách giá niêm yết của từng loại phòng.</p>
        </div>
        <a asp-action="LoaiPhongCreate" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Thêm loại phòng mới
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3" style="width: 25%;">Tên loại phòng</th>
                            <th class="text-center">Diện tích</th>
                            <th class="text-center">Số giường</th>
                            <th class="text-center">Sức chứa</th>
                            <th class="text-end">Giá niêm yết/đêm</th>
                            <th class="text-center">Số phòng hiện có</th>
                            <th class="text-center" style="width: 20%;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="fw-bold fs-5">@item.TenLoaiPhong</div>
                                        <div class="mt-1">
                                            @if (item.TienNghis != null && item.TienNghis.Any())
                                            {
                                                foreach (var tn in item.TienNghis)
                                                {
                                                    <span class="badge bg-light text-secondary border me-1 mb-1">
                                                        <i class="bi bi-check2-circle text-success me-1"></i>@tn.TenTienNghi
                                                    </span>
                                                }
                                            }
                                            else
                                            {
                                                <small class="text-muted font-italic">Không có tiện nghi ghi nhận</small>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-center">@item.DienTich m²</td>
                                    <td class="text-center">@item.SoGiuong giường</td>
                                    <td class="text-center">@item.SucChua người</td>
                                    <td class="text-end fw-bold text-success">@item.GiaNiemYet.ToString("N0") đ</td>
                                    <td class="text-center">
                                        <span class="badge bg-info text-dark rounded-pill fs-6 px-3">
                                            @(item.Phongs?.Count(p => !p.IsDeleted) ?? 0) phòng
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="LoaiPhongEdit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                                <i class="bi bi-pencil-square"></i> Sửa
                                            </a>
                                            <form asp-action="LoaiPhongDelete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa loại phòng này không? Hành động này không thể hoàn tác.');" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i> Xóa
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center p-5 text-muted">
                                    <i class="bi bi-door-closed display-4 d-block mb-3"></i>
                                    Chưa có loại phòng nào được tạo trên hệ thống.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
