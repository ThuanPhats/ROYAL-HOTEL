@model IEnumerable<QLKhachSan.Models.ChinhSachGia>
@{
    ViewData["Title"] = "Quản lý bảng giá & chính sách giá";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary mb-1"><i class="bi bi-tags me-2"></i>Bảng giá & Chính sách giá</h2>
            <p class="text-muted mb-0">Thiết lập đơn giá phòng áp dụng theo thời kỳ, loại phòng và số đêm lưu trú tối thiểu.</p>
        </div>
        <a asp-action="RatePlanCreate" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Thêm bảng giá mới
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3">Tên bảng giá (Chính sách)</th>
                            <th>Loại phòng</th>
                            <th class="text-center">Định mức loại giá</th>
                            <th class="text-end">Đơn giá áp dụng</th>
                            <th class="text-center">Số đêm tối thiểu</th>
                            <th class="text-center">Hiệu lực</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center" style="width: 15%;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                bool isExpired = item.NgayKetThuc < DateTime.Today;
                                <tr class="@(isExpired ? "table-danger" : "")">
                                    <td class="ps-3 fw-bold">
                                        @item.TenChinhSach
                                        @if (isExpired)
                                        {
                                            <span class="badge bg-danger ms-2"><i class="bi bi-exclamation-circle me-1"></i>Hết hạn</span>
                                        }
                                    </td>
                                    <td>@(item.LoaiPhong?.TenLoaiPhong ?? "Mọi loại phòng")</td>
                                    <td class="text-center text-secondary">
                                        @if (item.TenChinhSach.Contains("VIP", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge bg-purple text-dark border-purple border bg-opacity-10">VIP</span>
                                        }
                                        else if (item.TenChinhSach.Contains("Cuối tuần", StringComparison.OrdinalIgnoreCase) || item.TenChinhSach.Contains("Weekend", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge bg-info text-dark border-info border bg-opacity-10">Cuối tuần</span>
                                        }
                                        else if (item.TenChinhSach.Contains("Lễ", StringComparison.OrdinalIgnoreCase) || item.TenChinhSach.Contains("Holiday", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge bg-danger text-danger border-danger border bg-opacity-10">Lễ hội</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark border">Thường</span>
                                        }
                                    </td>
                                    <td class="text-end fw-bold text-success">@item.GiaApDung.ToString("N0") đ</td>
                                    <td class="text-center">@item.SoDemToiThieu đêm</td>
                                    <td class="text-center" style="font-size: 0.9rem;">
                                        @item.NgayBatDau.ToString("dd/MM/yyyy") - @item.NgayKetThuc.ToString("dd/MM/yyyy")
                                    </td>
                                    <td class="text-center">
                                        @if (item.IsActive && !isExpired)
                                        {
                                            <span class="badge bg-success">Đang áp dụng</span>
                                        }
                                        else if (!item.IsActive)
                                        {
                                            <span class="badge bg-secondary">Vô hiệu hóa</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Hết hiệu lực</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="RatePlanEdit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                                <i class="bi bi-pencil-square"></i> Sửa
                                            </a>
                                            <form asp-action="RatePlanDelete" asp-route-id="@item.Id" method="post" 
                                                  onsubmit="return confirm('Bạn có chắc muốn xóa chính sách giá này?');" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i> Xóa
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center p-5 text-muted">
                                    <i class="bi bi-tags display-4 d-block mb-3"></i>
                                    Chưa cấu hình chính sách giá nào trên hệ thống.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-purple { background-color: #f3e5f5; }
    .border-purple { border-color: #ab47bc; }
    .text-purple { color: #8e24aa; }
</style>
