@model IEnumerable<QLKhachSan.Models.TienNghi>
@{
    ViewData["Title"] = "Quản lý tiện nghi phòng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary mb-1"><i class="bi bi-box-fill me-2"></i>Danh sách tiện nghi phòng</h2>
            <p class="text-muted mb-0">Quản lý các tiện nghi, trang thiết bị tiêu chuẩn cung cấp trong phòng khách sạn.</p>
        </div>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="bi bi-plus-circle me-1"></i>Thêm tiện nghi mới
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3" style="width: 15%;">Mã tiện nghi</th>
                            <th style="width: 30%;">Tên tiện nghi</th>
                            <th>Mô tả tiện nghi</th>
                            <th class="text-center" style="width: 20%;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold text-secondary">#@item.Id</td>
                                    <td class="fw-bold">@item.TenTienNghi</td>
                                    <td>@(item.MoTa ?? "-")</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <button type="button" class="btn btn-sm btn-outline-warning edit-btn" 
                                                    data-bs-toggle="modal" data-bs-target="#editModal"
                                                    data-id="@item.Id" data-name="@item.TenTienNghi" data-desc="@item.MoTa">
                                                <i class="bi bi-pencil-square"></i> Sửa
                                            </button>
                                            <form asp-action="TienNghiDelete" asp-route-id="@item.Id" method="post" 
                                                  onsubmit="return confirm('Bạn có chắc chắn muốn xóa tiện nghi này?');" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i> Xóa
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center p-5 text-muted">
                                    <i class="bi bi-box display-4 d-block mb-3"></i>
                                    Chưa có tiện nghi nào được khai báo.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createModalLabel"><i class="bi bi-plus-circle me-2"></i>Thêm tiện nghi mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="TienNghiCreate" method="post" asp-antiforgery="true">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label for="createName" class="form-label font-weight-bold">Tên tiện nghi</label>
                        <input type="text" id="createName" name="TenTienNghi" class="form-control" placeholder="Ví dụ: Tủ lạnh, Điều hòa, Bồn tắm..." required />
                    </div>
                    <div class="mb-3">
                        <label for="createDesc" class="form-label font-weight-bold">Mô tả chi tiết</label>
                        <textarea id="createDesc" name="MoTa" class="form-control" rows="3" placeholder="Mô tả thông số hoặc chi tiết tiện nghi..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary">Lưu tiện nghi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title" id="editModalLabel"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa tiện nghi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="TienNghiEdit" method="post" asp-antiforgery="true">
                <div class="modal-body p-4">
                    <input type="hidden" id="editId" name="Id" />
                    <div class="mb-3">
                        <label for="editName" class="form-label font-weight-bold">Tên tiện nghi</label>
                        <input type="text" id="editName" name="TenTienNghi" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label for="editDesc" class="form-label font-weight-bold">Mô tả chi tiết</label>
                        <textarea id="editDesc" name="MoTa" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-warning">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const editModal = document.getElementById('editModal');
    if (editModal) {
        editModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            const name = button.getAttribute('data-name');
            const desc = button.getAttribute('data-desc');
            
            editModal.querySelector('#editId').value = id;
            editModal.querySelector('#editName').value = name;
            editModal.querySelector('#editDesc').value = desc;
        });
    }
</script>
