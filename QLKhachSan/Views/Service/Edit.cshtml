@model QLKhachSan.Models.DichVu
@{
    ViewData["Title"] = "Chỉnh sửa dịch vụ";
    var categories = ViewBag.Categories as IEnumerable<QLKhachSan.Models.DanhMucDichVu>;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="d-flex align-items-center mb-4">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary me-3 rounded-circle" style="width: 40px; height: 40px; line-height: 24px; padding: 6px 0;">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <h3 class="font-weight-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
                    Chỉnh Sửa Dịch Vụ
                </h3>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                    <div class="mb-3">
                        <label asp-for="TenDichVu" class="form-label font-weight-bold text-muted small"></label>
                        <input asp-for="TenDichVu" class="form-control rounded-3" placeholder="Nhập tên dịch vụ..." required />
                        <span asp-validation-for="TenDichVu" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DonGia" class="form-label font-weight-bold text-muted small"></label>
                            <div class="input-group">
                                <input asp-for="DonGia" type="number" class="form-control rounded-start-3" min="0" placeholder="0" required />
                                <span class="input-group-text rounded-end-3">đ</span>
                            </div>
                            <span asp-validation-for="DonGia" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DonViTinh" class="form-label font-weight-bold text-muted small"></label>
                            <input asp-for="DonViTinh" class="form-control rounded-3" placeholder="VD: Chai, Lượt, Dĩa..." required />
                            <span asp-validation-for="DonViTinh" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DanhMucDichVuId" class="form-label font-weight-bold text-muted small"></label>
                        <select asp-for="DanhMucDichVuId" class="form-select rounded-3" required>
                            <option value="">-- Chọn nhóm dịch vụ --</option>
                            @if (categories != null)
                            {
                                foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.TenNhom</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="DanhMucDichVuId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-2 border-top">
                        <a href="@Url.Action("Index")" class="btn btn-light px-4 py-2 rounded-3 border">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary px-4 py-2 rounded-3 font-weight-bold">
                            <i class="fa-solid fa-floppy-disk me-2"></i>Cập nhật thông tin
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
