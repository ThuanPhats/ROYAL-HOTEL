@model IEnumerable<QLKhachSan.Models.DichVu>
@{
    ViewData["Title"] = "Quản lý dịch vụ";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h3 class="font-weight-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
                <i class="fa-solid fa-bell-concierge text-primary me-2"></i>Quản lý Dịch vụ Khách sạn
            </h3>
            <p class="text-muted mb-0 small">Danh sách các dịch vụ ăn uống, giặt là, spa, giải trí cung cấp tại khách sạn.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("OrderIndex")" class="btn btn-outline-primary rounded-3">
                <i class="fa-solid fa-list-check me-2"></i>Lịch sử gọi dịch vụ
            </a>
            <a href="@Url.Action("Order")" class="btn btn-success rounded-3">
                <i class="fa-solid fa-cart-plus me-2"></i>Ghi nhận gọi dịch vụ (Order)
            </a>
            @if (User.IsInRole("Admin") || User.IsInRole("QuanLy"))
            {
                <a href="@Url.Action("Create")" class="btn btn-primary rounded-3">
                    <i class="fa-solid fa-plus me-2"></i>Thêm dịch vụ mới
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 p-4">
        <div class="table-responsive border rounded-3">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th width="80" class="text-center">ID</th>
                        <th>Tên dịch vụ</th>
                        <th>Nhóm dịch vụ</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-center">ĐVT</th>
                        @if (User.IsInRole("Admin") || User.IsInRole("QuanLy"))
                        {
                            <th width="150" class="text-center">Thao tác</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderBy(s => s.DanhMucDichVu?.TenNhom).ThenBy(s => s.TenDichVu))
                    {
                        <tr>
                            <td class="text-center text-muted">@item.Id</td>
                            <td>
                                <strong class="text-dark">@item.TenDichVu</strong>
                            </td>
                            <td>
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3 py-2">
                                    <i class="fa-solid fa-tag me-1"></i> @(item.DanhMucDichVu?.TenNhom ?? "Chưa phân nhóm")
                                </span>
                            </td>
                            <td class="text-end font-weight-bold text-primary">@item.DonGia.ToString("N0") đ</td>
                            <td class="text-center text-muted">@item.DonViTinh</td>
                            @if (User.IsInRole("Admin") || User.IsInRole("QuanLy"))
                            {
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-outline-warning btn-sm rounded-2" title="Chỉnh sửa">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa dịch vụ này?');" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-2" title="Xóa">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="@(User.IsInRole("Admin") || User.IsInRole("QuanLy") ? 6 : 5)" class="text-center text-muted py-5">
                                <i class="fa-solid fa-ban fs-2 text-secondary mb-3 d-block"></i>
                                Không có dịch vụ nào trên hệ thống.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
