@model QLKhachSan.Models.PhieuSuDungDichVu
@{
    ViewData["Title"] = "Ghi nhận gọi dịch vụ";
    var services = ViewBag.Services as IEnumerable<QLKhachSan.Models.DichVu>;
    var folios = ViewBag.ActiveFolios as IEnumerable<QLKhachSan.Models.PhieuLuuTru>;
    var paymentMethods = ViewBag.PaymentMethods as IEnumerable<QLKhachSan.Models.HinhThucThanhToan>;
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary me-3 rounded-circle" style="width: 40px; height: 40px; line-height: 24px; padding: 6px 0;">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h3 class="font-weight-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
            Ghi Nhận Sử Dụng Dịch Vụ
        </h3>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger rounded-3 shadow-sm border-0" role="alert">
            <div asp-validation-summary="All" class="small"></div>
        </div>
    }

    <form asp-action="Order" method="post" id="orderForm">
        @Html.AntiForgeryToken()

        <div class="row g-4">
            <!-- Cột trái: Chọn dịch vụ -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="font-weight-bold mb-4 text-dark" style="font-family: 'Outfit', sans-serif;">
                        <i class="fa-solid fa-cart-shopping text-primary me-2"></i>Danh sách dịch vụ khả dụng
                    </h5>

                    <!-- Tìm kiếm & Lọc nhóm dịch vụ -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-7">
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa-solid fa-magnifying-glass"></i></span>
                                <input type="text" id="searchService" class="form-control border-start-0 rounded-end-3" placeholder="Tìm tên dịch vụ..." />
                            </div>
                        </div>
                        <div class="col-md-5">
                            <select id="filterCategory" class="form-select rounded-3">
                                <option value="">-- Tất cả nhóm dịch vụ --</option>
                                @if (services != null)
                                {
                                    var categories = services.Select(s => s.DanhMucDichVu?.TenNhom).Distinct().Where(c => c != null);
                                    foreach (var cat in categories)
                                    {
                                        <option value="@cat">@cat</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Bảng chọn dịch vụ -->
                    <div class="table-responsive border rounded-3" style="max-height: 450px; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0" id="servicesTable">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th width="40" class="text-center">Chọn</th>
                                    <th>Tên dịch vụ</th>
                                    <th>Nhóm</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-center" width="100">Số lượng</th>
                                    <th class="text-center" width="180">Ghi chú / Chi tiết</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (services != null)
                                {
                                    foreach (var s in services.OrderBy(s => s.DanhMucDichVu?.TenNhom).ThenBy(s => s.TenDichVu))
                                    {
                                        <tr class="service-row" data-name="@s.TenDichVu.ToLower()" data-category="@(s.DanhMucDichVu?.TenNhom ?? "")">
                                            <td class="text-center">
                                                <input type="checkbox" class="form-check-input select-service-cb" data-id="@s.Id" data-price="@s.DonGia" />
                                            </td>
                                            <td>
                                                <strong class="text-dark">@s.TenDichVu</strong>
                                                <div class="small text-muted">ĐVT: @s.DonViTinh</div>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary-subtle text-secondary rounded-pill">@(s.DanhMucDichVu?.TenNhom ?? "Khác")</span>
                                            </td>
                                            <td class="text-end font-weight-bold text-primary">@s.DonGia.ToString("N0") đ</td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm text-center service-qty" value="1" min="1" disabled />
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm service-notes" placeholder="Số bàn, slot spa..." disabled />
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">Không tải được danh sách dịch vụ.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Cột phải: Gán phòng & Thanh toán -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                    <h5 class="font-weight-bold mb-4 text-dark" style="font-family: 'Outfit', sans-serif;">
                        <i class="fa-solid fa-door-open text-primary me-2"></i>Thông tin lưu trú
                    </h5>

                    <!-- Gán phòng -->
                    <div class="mb-3">
                        <label for="PhieuLuuTruId" class="form-label font-weight-bold text-muted small">Phòng đang lưu trú (Folio):</label>
                        <select asp-for="PhieuLuuTruId" class="form-select rounded-3" id="selectFolio">
                            <option value="">-- Chọn phòng sử dụng dịch vụ --</option>
                            @if (folios != null)
                            {
                                foreach (var f in folios.OrderBy(f => f.Phong?.MaPhong))
                                {
                                    <option value="@f.Id">Phòng @f.Phong?.MaPhong - @f.KhachHang?.HoTen (Folio: @f.MaFolio)</option>
                                }
                            }
                        </select>
                        <div class="form-text small">Nếu bỏ trống, phiếu dịch vụ sẽ mặc định là khách vãng lai và bắt buộc thanh toán tại quầy.</div>
                    </div>

                    <!-- Checkbox thanh toán riêng -->
                    <div class="form-check form-switch mb-3 p-0 ps-5 fs-6">
                        <input asp-for="DaThanhToanRieng" class="form-check-input" type="checkbox" id="checkPaymentNow">
                        <label class="form-check-label font-weight-bold text-dark" for="checkPaymentNow">Thanh toán ngay tại quầy</label>
                    </div>

                    <!-- Dropdown hình thức thanh toán -->
                    <div class="mb-4 d-none" id="paymentMethodSection">
                        <label for="billingMethodId" class="form-label font-weight-bold text-muted small">Phương thức thanh toán:</label>
                        <select name="billingMethodId" id="billingMethodId" class="form-select rounded-3">
                            <option value="">-- Chọn hình thức thanh toán --</option>
                            @if (paymentMethods != null)
                            {
                                foreach (var pm in paymentMethods)
                                {
                                    <option value="@pm.Id">@pm.TenHinhThuc</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <!-- Tóm tắt chi phí -->
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-light">
                    <h5 class="font-weight-bold mb-3 text-dark" style="font-family: 'Outfit', sans-serif;">
                        <i class="fa-solid fa-receipt text-primary me-2"></i>Tổng hợp hóa đơn
                    </h5>
                    <div class="d-flex justify-content-between mb-2 small text-muted">
                        <span>Số dịch vụ đã chọn:</span>
                        <span id="selectedCount">0</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-4">
                        <span class="font-weight-bold text-dark fs-5">TỔNG CỘNG:</span>
                        <span class="font-weight-bold text-primary fs-4" id="orderTotal">0 đ</span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 font-weight-bold fs-6" id="btnSubmitOrder" disabled>
                        <i class="fa-solid fa-check me-2"></i>Hoàn tất ghi nhận dịch vụ
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Live Search
            $('#searchService').on('keyup', function () {
                filterServices();
            });

            // Live Category Filter
            $('#filterCategory').on('change', function () {
                filterServices();
            });

            function filterServices() {
                let searchVal = $('#searchService').val().toLowerCase();
                let catVal = $('#filterCategory').val();

                $('.service-row').each(function () {
                    let name = $(this).data('name');
                    let category = $(this).data('category');

                    let matchesSearch = name.indexOf(searchVal) > -1;
                    let matchesCat = catVal === "" || category === catVal;

                    if (matchesSearch && matchesCat) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            }

            // Checkbox changes - Enable / Disable inputs and calculate total
            $('.select-service-cb').on('change', function () {
                let row = $(this).closest('tr');
                let isChecked = $(this).is(':checked');

                // Enable/disable inputs in the row
                row.find('.service-qty, .service-notes').prop('disabled', !isChecked);
                if (isChecked) {
                    row.addClass('table-primary-subtle');
                } else {
                    row.removeClass('table-primary-subtle');
                }

                calculateTotal();
            });

            // Quantity changes
            $('.service-qty').on('input change', function () {
                calculateTotal();
            });

            function calculateTotal() {
                let total = 0;
                let count = 0;

                $('.select-service-cb:checked').each(function () {
                    let qtyInput = $(this).closest('tr').find('.service-qty');
                    let qty = parseInt(qtyInput.val()) || 1;
                    let price = parseFloat($(this).data('price')) || 0;
                    total += qty * price;
                    count++;
                });

                $('#selectedCount').text(count);
                $('#orderTotal').text(total.toLocaleString('vi-VN') + ' đ');

                // Submit button enabling logic
                let isFolioSelected = $('#selectFolio').val() !== "";
                let isPayNow = $('#checkPaymentNow').is(':checked');
                
                // Disable submit if no items selected OR if (no folio selected AND not paying now)
                if (count > 0 && (isFolioSelected || isPayNow)) {
                    $('#btnSubmitOrder').removeAttr('disabled');
                } else {
                    $('#btnSubmitOrder').attr('disabled', 'disabled');
                }
            }

            // Sync Submit button on Folio dropdown change
            $('#selectFolio').on('change', function () {
                let val = $(this).val();
                if (val === "") {
                    // Force Check payment now
                    $('#checkPaymentNow').prop('checked', true).trigger('change');
                }
                calculateTotal();
            });

            // Toggle Payment Method view
            $('#checkPaymentNow').on('change', function () {
                let isChecked = $(this).is(':checked');
                let isFolioSelected = $('#selectFolio').val() !== "";

                if (!isChecked && !isFolioSelected) {
                    // Prevent unchecking payment now if no folio is selected
                    alert("Nếu không chọn phòng gán hóa đơn, bắt buộc phải thanh toán ngay tại quầy.");
                    $(this).prop('checked', true);
                    return;
                }

                if (isChecked) {
                    $('#paymentMethodSection').removeClass('d-none');
                    $('#billingMethodId').prop('required', true);
                } else {
                    $('#paymentMethodSection').addClass('d-none');
                    $('#billingMethodId').prop('required', false).val('');
                }
                calculateTotal();
            });

            // Before submit, construct the indices correctly so ASP.NET MVC binds it to List<ChiTietDichVu> orderDetails
            $('#orderForm').on('submit', function () {
                let index = 0;
                $('.select-service-cb:checked').each(function () {
                    let row = $(this).closest('tr');
                    let serviceId = $(this).data('id');
                    let qty = row.find('.service-qty').val();
                    let notes = row.find('.service-notes').val();

                    // Create hidden inputs for the model binding
                    let prefix = 'orderDetails[' + index + '].';
                    $('<input>').attr({ type: 'hidden', name: prefix + 'DichVuId', value: serviceId }).appendTo('#orderForm');
                    $('<input>').attr({ type: 'hidden', name: prefix + 'SoLuong', value: qty }).appendTo('#orderForm');
                    if (notes) {
                        $('<input>').attr({ type: 'hidden', name: prefix + 'GhiChu', value: notes }).appendTo('#orderForm');
                    }
                    index++;
                });

                return true;
            });

            // Initialize switch state
            $('#checkPaymentNow').trigger('change');
        });
    </script>
}
