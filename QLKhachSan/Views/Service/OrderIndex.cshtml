@model IEnumerable<QLKhachSan.Models.PhieuSuDungDichVu>
@{
    ViewData["Title"] = "Lịch sử gọi dịch vụ";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h3 class="font-weight-bold text-dark m-0" style="font-family: 'Outfit', sans-serif;">
                <i class="fa-solid fa-clock-rotate-left text-primary me-2"></i>Lịch sử gọi dịch vụ
            </h3>
            <p class="text-muted mb-0 small">Danh sách các phiếu sử dụng dịch vụ tại phòng hoặc thanh toán trực tiếp tại quầy.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-3">
                <i class="fa-solid fa-arrow-left me-2"></i>Danh sách dịch vụ
            </a>
            <a href="@Url.Action("Order")" class="btn btn-success rounded-3">
                <i class="fa-solid fa-cart-plus me-2"></i>Ghi nhận gọi dịch vụ (Order)
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 p-4">
        <div class="table-responsive border rounded-3">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th width="80" class="text-center">Số phiếu</th>
                        <th>Thời gian gọi</th>
                        <th>Vị trí / Folio</th>
                        <th>Hình thức ghi nhận</th>
                        <th>Nhân viên phục vụ</th>
                        <th class="text-end">Tổng tiền</th>
                        <th width="120" class="text-center">Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center text-muted font-weight-bold">#@item.Id</td>
                            <td>@item.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.PhieuLuuTruId.HasValue)
                                {
                                    <div><strong>Phòng @(item.Phong?.MaPhong ?? item.PhieuLuuTru?.Phong?.MaPhong)</strong></div>
                                    <small class="text-muted">Folio: @item.PhieuLuuTru?.MaFolio</small>
                                }
                                else
                                {
                                    <span class="text-secondary"><i class="fa-solid fa-store me-1"></i>Khách vãng lai</span>
                                }
                            </td>
                            <td>
                                @if (item.DaThanhToanRieng)
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-2">
                                        <i class="fa-solid fa-credit-card me-1"></i>Thanh toán tại quầy
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-primary rounded-pill px-3 py-2">
                                        <i class="fa-solid fa-file-invoice-dollar me-1"></i>Tính vào tiền phòng
                                    </span>
                                }
                            </td>
                            <td>@(item.NhanVien?.HoTen ?? "Hệ thống")</td>
                            <td class="text-end font-weight-bold text-dark">@item.TongTien.ToString("N0") đ</td>
                            <td class="text-center">
                                <button class="btn btn-outline-primary btn-sm rounded-2 px-3" type="button" data-bs-toggle="collapse" data-bs-target="#details-@item.Id" aria-expanded="false" aria-controls="details-@item.Id">
                                    <i class="fa-solid fa-chevron-down"></i> Xem
                                </button>
                            </td>
                        </tr>
                        <!-- Dòng collapse chi tiết dịch vụ -->
                        <tr class="collapse-row">
                            <td colspan="7" class="p-0 border-0">
                                <div class="collapse" id="details-@item.Id">
                                    <div class="bg-light p-4 border-bottom">
                                        <h6 class="font-weight-bold text-dark mb-3"><i class="fa-solid fa-receipt text-muted me-2"></i>Chi tiết các dịch vụ sử dụng:</h6>
                                        <div class="row">
                                            <div class="col-md-8 col-lg-6">
                                                <div class="card border-0 shadow-xs rounded-3 overflow-hidden">
                                                    <table class="table table-sm table-borderless align-middle mb-0">
                                                        <thead class="bg-secondary-subtle">
                                                            <tr>
                                                                <th class="ps-3 py-2 text-muted small">Tên dịch vụ</th>
                                                                <th class="text-center py-2 text-muted small">SL</th>
                                                                <th class="text-end py-2 text-muted small">Đơn giá</th>
                                                                <th class="text-end pe-3 py-2 text-muted small">Thành tiền</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var detail in item.ChiTietDichVus)
                                                            {
                                                                <tr class="border-bottom-dashed">
                                                                    <td class="ps-3 py-2">
                                                                        <strong class="text-dark small">@detail.DichVu?.TenDichVu</strong>
                                                                        @if (!string.IsNullOrEmpty(detail.GhiChu))
                                                                        {
                                                                            <div class="small text-muted font-italic fs-7">Ghi chú: @detail.GhiChu</div>
                                                                        }
                                                                    </td>
                                                                    <td class="text-center py-2 small text-muted">@detail.SoLuong</td>
                                                                    <td class="text-end py-2 small text-muted">@detail.DonGia.ToString("N0") đ</td>
                                                                    <td class="text-end pe-3 py-2 font-weight-bold text-dark small">@detail.ThanhTien.ToString("N0") đ</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <i class="fa-solid fa-box-open fs-2 text-secondary mb-3 d-block"></i>
                                Chưa có ghi nhận sử dụng dịch vụ nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .collapse-row {
        background-color: #fcfcfc;
    }
    .border-bottom-dashed {
        border-bottom: 1px dashed #dee2e6 !important;
    }
    .fs-7 {
        font-size: 0.75rem;
    }
</style>
